---
interface Props {
    active?: 'events' | 'calendar' | 'saved';
}

const { active = 'events' } = Astro.props;

const tabs = [
    {
        id: 'events',
        label: 'Events',
        href: '/events',
        icon: 'M3 9.5L11 3l8 6.5V19a1 1 0 01-1 1h-4v-6h-6v6H4a1 1 0 01-1-1V9.5z',
    },
    {
        id: 'calendar',
        label: 'Calendar',
        href: '/calendar',
        icon: 'M3 8h16M5 4h12a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2zM7 2v4M15 2v4',
    },
    {
        id: 'saved',
        label: 'Saved',
        href: '/saved',
        icon: 'M5 3h12a1 1 0 011 1v16l-7-4-7 4V4a1 1 0 011-1z',
    },
] as const;
---

<nav
    class="fixed bottom-4 left-1/2 z-50 -translate-x-1/2"
    style="padding-bottom: env(safe-area-inset-bottom)"
    aria-label="Main"
>
    <div class="dock-surface flex items-stretch gap-1 rounded-[32px] p-2">
        {
            tabs.map((tab) => {
                const isActive = tab.id === active;
                return (
                    <a
                        href={tab.href}
                        class:list={[
                            'press-sm dock-tab relative overflow-hidden text-gray-500',
                            'flex flex-col items-center justify-center gap-1 rounded-[22px]',
                            !isActive && 'dock-tab-inactive',
                        ]}
                        aria-current={isActive ? 'page' : undefined}
                        aria-label={tab.label}
                    >
                        <span class="dock-tab-base flex flex-col items-center justify-center gap-1" aria-hidden="true">
                            <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="dock-icon">
                                <path
                                    d={tab.icon}
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    fill="none"
                                />
                            </svg>
                            <span class="dock-tab-label text-[11px] font-semibold">{tab.label}</span>
                        </span>
                        {isActive && (
                            <span
                                class="dock-tab-active pointer-events-none absolute inset-0 flex flex-col items-center justify-center gap-1 rounded-[22px] text-white"
                                aria-hidden="true"
                            >
                                <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="dock-icon">
                                    <path
                                        d={tab.icon}
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        fill="rgba(255,255,255,0.18)"
                                    />
                                </svg>
                                <span class="dock-tab-label text-[11px] font-bold">{tab.label}</span>
                            </span>
                        )}
                    </a>
                );
            })
        }
    </div>
</nav>

<style>
    .dock-surface {
        background: linear-gradient(180deg, #ffffff 0%, #fafaf9 100%);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 1),
            inset 0 0 0 1px rgba(15, 15, 15, 0.04),
            0 1px 2px rgba(15, 15, 15, 0.06),
            0 8px 20px rgba(15, 15, 15, 0.1),
            0 24px 48px rgba(15, 15, 15, 0.08);
        /* Without a dedicated VT name, the root cross-fade leaves the dock
           ~75% opaque mid-transition and page text bleeds through. */
        view-transition-name: dock-surface;
        transition: padding 280ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    /* Tab default (expanded) sizing — owned by CSS so it's transitionable */
    .dock-tab {
        width: 5rem; /* w-20 */
        padding: 0.625rem 0.75rem; /* py-2.5 px-3 */
        transition:
            width 280ms cubic-bezier(0.22, 1, 0.36, 1),
            padding 280ms cubic-bezier(0.22, 1, 0.36, 1);
    }
    .dock-tab-label {
        overflow: hidden;
        max-height: 1rem;
        line-height: 1rem;
        transition:
            max-height 220ms cubic-bezier(0.22, 1, 0.36, 1),
            opacity 160ms ease-out;
    }

    /* Collapsed state — icons-only compact pill.
       Triggered by [data-collapsed] on <nav>, set by the scroll-direction
       script below. Surface padding tightens, tabs lose their horizontal
       padding and shrink in width, labels collapse to zero height. */
    nav[data-collapsed='true'] .dock-surface {
        padding: 0.375rem;
    }
    nav[data-collapsed='true'] .dock-tab {
        width: 3rem;
        padding: 0.375rem 0.25rem;
    }
    nav[data-collapsed='true'] .dock-tab-label {
        max-height: 0;
        opacity: 0;
    }
    .dock-tab-active {
        background: linear-gradient(180deg, #c084fc 0%, #9333ea 100%);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.4),
            inset 0 -1px 0 rgba(0, 0, 0, 0.15),
            0 1px 2px rgba(80, 20, 160, 0.25),
            0 4px 12px rgba(147, 51, 234, 0.4);
        animation: dock-pop-in 360ms cubic-bezier(0.34, 1.56, 0.64, 1);
        view-transition-name: dock-active-pill;
    }

    /* The inactive base for every tab remains in the dock-surface snapshot.
       The active visual is an overlay so when the VT pill slides away, the
       newly inactive tab is already painted underneath instead of leaving a
       temporary blank slot. */
    .dock-tab-active {
        pointer-events: none;
    }

    /* Active pill enters with a tiny pop — runs once per page load.
       User-triggered (the tap that brought them here), so it respects
       principle #5 (tactility ON, ambient motion OFF). */
    @keyframes dock-pop-in {
        0% {
            transform: scale(0.82);
        }
        55% {
            transform: scale(1.08);
        }
        100% {
            transform: scale(1);
        }
    }

    /* Icon settles in alongside the pill — staggered slightly */
    .dock-tab-active .dock-icon {
        animation: dock-icon-in 420ms 60ms cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
    }
    @keyframes dock-icon-in {
        0% {
            transform: scale(0.6);
            opacity: 0;
        }
        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    /* Inactive tabs — lift + tint on desktop hover only */
    @media (hover: hover) and (pointer: fine) {
        .dock-tab-inactive {
            transition:
                color 200ms cubic-bezier(0.2, 0, 0, 1),
                transform 200ms cubic-bezier(0.2, 0, 0, 1);
        }
        .dock-tab-inactive:hover {
            color: rgb(126, 34, 206);
            transform: translateY(-2px);
        }
        .dock-tab-inactive .dock-icon {
            transition: transform 200ms cubic-bezier(0.2, 0, 0, 1);
        }
        .dock-tab-inactive:hover .dock-icon {
            transform: scale(1.08);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .dock-tab-active,
        .dock-tab-active .dock-icon,
        .dock-tab-inactive,
        .dock-tab-inactive:hover,
        .dock-tab-inactive .dock-icon,
        .dock-tab-inactive:hover .dock-icon,
        .dock-surface,
        .dock-tab,
        .dock-tab-label {
            animation: none;
            transition: none;
            transform: none;
        }
    }
</style>

{
    /* View-transition pseudo-element overrides — kept global because Astro's
    component scoping can break `::view-transition-*(name)` selectors. */
}
<style is:global>
    /* Dock surface: skip the cross-fade entirely. The surface is identical
       across pages (only the active pill differs) so an instant swap looks
       solid; without this, the default crossfade leaves it ~75% opaque
       mid-transition and page text shows through. */
    ::view-transition-group(dock-surface) {
        z-index: 50;
    }
    ::view-transition-old(dock-surface) {
        animation: none;
        opacity: 0;
    }
    ::view-transition-new(dock-surface) {
        animation: none;
        opacity: 1;
    }

    /* Active pill: slide morph (GROUP bounds animation) with bouncy easing.
       The image-pair crossfade is suppressed — old hides instantly, new
       stays opaque from frame 0 — so the pill stays solid mid-slide instead
       of becoming ~75% opaque and showing the inactive-tab labels behind it. */
    ::view-transition-group(dock-active-pill) {
        animation-duration: 360ms;
        animation-timing-function: cubic-bezier(0.34, 1.56, 0.64, 1);
        z-index: 51;
    }
    ::view-transition-old(dock-active-pill) {
        animation: none;
        opacity: 0;
    }
    ::view-transition-new(dock-active-pill) {
        animation: none;
        opacity: 1;
    }

    @media (prefers-reduced-motion: reduce) {
        ::view-transition-group(dock-active-pill) {
            animation: none;
        }
    }
</style>

{
    /* Dock taps are section switches, not flow continuations — strip
    page-content VT names so only the dock chrome (which lives outside
    <main>) morphs. */
}
<script is:inline>
    (() => {
        const dock = document.querySelector('nav[aria-label="Main"]');
        if (!dock) return;
        dock.querySelectorAll('a[href]').forEach((link) => {
            link.addEventListener('click', () => {
                document.querySelectorAll('main [style*="view-transition-name"]').forEach((el) => {
                    el.style.viewTransitionName = '';
                });
                // Subscribe card uses CSS-gated names — remove the attribute to disable them.
                document.getElementById('subscribe-card-host')?.removeAttribute('data-vt-active');
            });
        });
    })();
</script>

{
    /* Scroll-direction collapse — minimize dock to icons-only while the
    user is scrolling down through content, restore on scroll up.

    Two-stage filter to keep the dock calm:
      1. DEADBAND — must move 28px in one direction from the last anchor
         before we even consider a state change.
      2. COMMIT_DELAY — once the deadband crosses, schedule the change
         140ms out. If the user reverses direction during that window,
         cancel the pending change. This eliminates the dock flipping
         on the brief direction wobble that normal scrolling produces.

    Near the top we always force-expand so a quick bounce doesn't
    leave the dock minimized when the user is clearly idle. */
}
<script is:inline>
    (() => {
        const dock = document.querySelector('nav[aria-label="Main"]');
        if (!dock) return;

        const DEADBAND = 28;
        const COMMIT_DELAY = 140;
        const NEAR_TOP = 80;

        let anchor = window.scrollY;
        let ticking = false;
        let pendingTimer = null;
        let pendingState = null;

        const isCollapsed = () => dock.getAttribute('data-collapsed') === 'true';

        const applyCollapsed = (collapsed) => {
            if (collapsed) dock.setAttribute('data-collapsed', 'true');
            else dock.removeAttribute('data-collapsed');
        };

        const cancelPending = () => {
            if (pendingTimer !== null) {
                clearTimeout(pendingTimer);
                pendingTimer = null;
                pendingState = null;
            }
        };

        const schedule = (collapsed) => {
            // Already in target state (or already scheduled to be) — skip.
            if (collapsed === isCollapsed() && pendingState === null) return;
            if (pendingState === collapsed) return;

            cancelPending();
            pendingState = collapsed;
            pendingTimer = window.setTimeout(() => {
                applyCollapsed(collapsed);
                pendingTimer = null;
                pendingState = null;
            }, COMMIT_DELAY);
        };

        const update = () => {
            ticking = false;
            const y = window.scrollY;

            if (y < NEAR_TOP) {
                cancelPending();
                applyCollapsed(false);
                anchor = y;
                return;
            }

            const delta = y - anchor;
            if (delta > DEADBAND) {
                schedule(true);
                anchor = y;
            } else if (delta < -DEADBAND) {
                schedule(false);
                anchor = y;
            }
        };

        window.addEventListener(
            'scroll',
            () => {
                if (ticking) return;
                ticking = true;
                requestAnimationFrame(update);
            },
            { passive: true },
        );
    })();
</script>
