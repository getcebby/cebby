---
interface Props {
    showSearch?: boolean;
    tagline?: string;
}

const { showSearch = true, tagline } = Astro.props;
---

<header
    class:list={[
        'mx-auto flex max-w-2xl items-center px-5 pt-10 pb-6',
        // Center the wordmark when there's no right-side affordance (home).
        // Otherwise sit it on the left so the search/etc affordance has its right rail.
        showSearch ? 'justify-between' : 'justify-center',
    ]}
>
    <a href="/events" class="press-sm wordmark-link leading-none" aria-label="cebby — home">
        <span class="wordmark text-5xl text-purple-600 lowercase" aria-hidden="true">
            <span class="wordmark-letter" style="--i: 0">c</span><span class="wordmark-letter" style="--i: 1">e</span><span class="wordmark-letter" style="--i: 2">b</span><span class="wordmark-letter" style="--i: 3">b</span><span class="wordmark-letter" style="--i: 4">y</span>
        </span>
        {tagline && <p class="mt-1 text-sm text-gray-500">{tagline}</p>}
    </a>
    {
        showSearch && (
            <a
                href="/search"
                class="press-sm shadow-soft-1 flex h-10 w-10 items-center justify-center rounded-full bg-white text-gray-700 transition-transform duration-200 hover:scale-105 hover:text-purple-700 motion-reduce:hover:scale-100"
                aria-label="Search"
            >
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path
                        d="M8 14a6 6 0 100-12 6 6 0 000 12zM16 16l-3.5-3.5"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                    />
                </svg>
            </a>
        )
    }
</header>
