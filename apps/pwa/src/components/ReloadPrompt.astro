---

---

<script src="./pwa.ts"></script>
<div
    id="pwa-toast"
    role="alert"
    aria-labelledby="toast-message"
    class="fixed bottom-[120px] right-4 z-40 w-full max-w-sm transform px-4 transition-all duration-300 ease-out sm:bottom-6 sm:right-6 sm:px-0"
>
    <div class="card-tactile p-5">
        <div class="flex items-start gap-3">
            <div
                class="date-chip date-chip-purple flex h-10 w-10 flex-shrink-0 items-center justify-center"
                style="padding: 0"
            >
                <svg class="h-5 w-5 text-purple-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.75"
                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
            </div>
            <div class="min-w-0 flex-1 pt-1.5">
                <p id="toast-message" class="text-sm font-semibold text-gray-700"></p>
            </div>
        </div>
        <div class="mt-4 flex justify-end gap-2">
            <button id="pwa-refresh" class="press-sm btn-primary-tactile">Reload</button>
            <button id="pwa-close" class="press-sm chip-tactile chip-inactive !text-[13px]">Close</button>
        </div>
    </div>
</div>

<style>
    #pwa-toast {
        z-index: 40;
        visibility: hidden;
        opacity: 0;
        transform: translateY(8px);
    }

    #pwa-toast.show {
        visibility: visible;
        opacity: 1;
        transform: translateY(0);
    }

    button#pwa-refresh {
        display: none;
    }

    #pwa-toast.show.refresh button#pwa-refresh {
        display: inline-flex;
    }

    @media (max-width: 640px) {
        #pwa-toast {
            max-width: calc(100vw - 2rem);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        #pwa-toast {
            transition: none;
        }
    }
</style>
