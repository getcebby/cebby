---
const currentYear = new Date().getFullYear();

const explore = [
    { name: 'Events', href: '/events' },
    { name: 'Calendar', href: '/calendar' },
    { name: 'Saved', href: '/saved' },
    { name: 'Communities', href: '/partners' },
];

const project = [
    { name: 'How Cebby verifies events', href: '/how-cebby-verifies-events' },
    { name: 'About OneCebby', href: '/about-onecebby' },
    { name: 'Changelog', href: '/changelog' },
    { name: 'Roadmap', href: 'https://getcebby.notion.site/?v=1263f8eda070810eb633000cf6c1e421', external: true },
    { name: 'GitHub', href: 'https://github.com/getcebby/cebby', external: true },
];

const legal = [
    { name: 'Terms', href: '/terms' },
    { name: 'Privacy', href: '/privacy' },
];
---

<footer class="hidden sm:block mt-16 pb-10">
    <div class="mx-auto max-w-3xl px-5">
        <div class="card-tactile p-8">
            <div class="grid gap-8 sm:grid-cols-3">
                {/* Brand */}
                <div class="sm:col-span-1">
                    <a href="/" class="wordmark text-3xl text-purple-700">cebby</a>
                    <p class="mt-3 max-w-xs text-sm text-gray-500">
                        Cebu tech events, with sources you can verify. A public utility for the local community.
                    </p>
                </div>

                {/* Explore */}
                <div>
                    <h3 class="mb-3 text-[10px] font-bold uppercase tracking-widest text-gray-500">Explore</h3>
                    <ul class="space-y-2">
                        {
                            explore.map((link) => (
                                <li>
                                    <a
                                        href={link.href}
                                        class="text-sm font-semibold text-gray-700 transition-colors hover:text-purple-700"
                                    >
                                        {link.name}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>

                {/* Project */}
                <div>
                    <h3 class="mb-3 text-[10px] font-bold uppercase tracking-widest text-gray-500">Project</h3>
                    <ul class="space-y-2">
                        {
                            project.map((link) => (
                                <li>
                                    <a
                                        href={link.href}
                                        target={link.external ? '_blank' : undefined}
                                        rel={link.external ? 'noopener noreferrer' : undefined}
                                        class="inline-flex items-center gap-1 text-sm font-semibold text-gray-700 transition-colors hover:text-purple-700"
                                    >
                                        {link.name}
                                        {link.external && (
                                            <svg
                                                width="11"
                                                height="11"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2.5"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="opacity-40"
                                            >
                                                <path d="M7 17L17 7M9 7h8v8" />
                                            </svg>
                                        )}
                                    </a>
                                </li>
                            ))
                        }
                        <li>
                            <button
                                type="button"
                                data-open-feedback
                                class="press-sm inline-flex items-center gap-1 text-sm font-semibold text-gray-700 transition-colors hover:text-purple-700"
                            >
                                Send feedback
                            </button>
                        </li>
                    </ul>
                </div>
            </div>

            {/* Bottom strip */}
            <div class="mt-8 flex flex-col gap-3 border-t border-stone-200/60 pt-5 sm:flex-row sm:items-center sm:justify-between">
                <span class="text-xs text-gray-500">
                    © {currentYear} Cebby — open-source, made with care for Cebu tech.
                </span>
                <div class="flex items-center gap-4">
                    {
                        legal.map((link) => (
                            <a
                                href={link.href}
                                class="text-xs font-semibold text-gray-500 hover:text-purple-700"
                            >
                                {link.name}
                            </a>
                        ))
                    }
                    <a
                        href="https://github.com/getcebby/cebby"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Cebby on GitHub"
                        class="press-sm flex h-8 w-8 items-center justify-center rounded-full bg-stone-50 text-gray-500 transition-transform duration-200 hover:scale-110 hover:text-purple-700 motion-reduce:hover:scale-100"
                    >
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                            <path
                                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                            />
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</footer>
