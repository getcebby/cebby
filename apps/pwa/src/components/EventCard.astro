---
import type { EventFromDB } from '../types/database';
import { getEventTimeDisplay } from '../utils/date';
import { Image } from 'astro:assets';
import VenueChip from './VenueChip.astro';

interface Props {
    event: EventFromDB;
    variant?: 'upcoming' | 'recent' | 'past';
}

const { event, variant = 'upcoming' } = Astro.props;

const eventDate = new Date(event.start_time);
const day = eventDate.getDate().toString().padStart(2, '0');
const month = eventDate.toLocaleString('default', { month: 'short' });

const detailPageUrl = `/events/${event.slug || event.id}`;
const timeDisplay = getEventTimeDisplay(event.start_time, event.end_time ?? undefined);
// `variant` stays in the API as a hook for future per-context styling, but
// past/recent no longer auto-dim — the section heading already provides
// temporal context, and the dim was making the homepage hero peek look stale.
---

<a
    href={detailPageUrl}
    class="press lift-hover card-tactile block overflow-hidden"
    data-astro-prefetch="viewport"
>
    {
        event.cover_photo ? (
            <div class="relative aspect-[16/9] overflow-hidden">
                <Image
                    src={event.cover_photo}
                    alt={event.name}
                    width={800}
                    height={450}
                    loading="lazy"
                    class="cover-zoom h-full w-full object-cover"
                />
                <div class="date-chip absolute left-4 top-4 text-center">
                    <div class="text-xl font-extrabold leading-none text-gray-900">{day}</div>
                    <div class="mt-1 text-[10px] font-bold uppercase tracking-wider text-gray-500">
                        {month}
                    </div>
                </div>
            </div>
        ) : null
    }

    <div class="p-5">
        {
            !event.cover_photo && (
                <div class="mb-3 flex items-start justify-between">
                    <div class="date-chip date-chip-purple inline-block text-center">
                        <div class="text-xl font-extrabold leading-none text-purple-900">{day}</div>
                        <div class="mt-1 text-[10px] font-bold uppercase tracking-wider text-purple-700">
                            {month}
                        </div>
                    </div>
                    {event?.account_id && (
                        <span class="pill-tactile pill-emerald">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 6 9 17l-5-5" />
                            </svg>
                            Verified
                        </span>
                    )}
                </div>
            )
        }

        <h3 class="mb-1.5 text-lg font-extrabold leading-snug text-gray-900 line-clamp-2">
            {event.name}
        </h3>

        <p class="text-sm text-gray-500 line-clamp-1">
            <time datetime={event.start_time}>{timeDisplay}</time>
        </p>

        {(event.location || event.is_online) && (
            <div class="mt-2">
                <VenueChip location={event.location} isOnline={event.is_online} />
            </div>
        )}
    </div>
</a>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
