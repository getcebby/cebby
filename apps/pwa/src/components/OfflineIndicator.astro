<div
    id="offlineIndicator"
    class="fixed bottom-20 left-4 right-4 z-50 transform translate-y-full opacity-0 transition-all duration-300 sm:bottom-6 sm:left-auto sm:right-6 sm:w-96"
>
    <div class="card-tactile p-4">
        <div class="flex items-center gap-3">
            <span class="pill-tactile pill-amber" id="offlineStatusPill">Offline</span>
            <div class="min-w-0 flex-1">
                <p class="text-sm font-extrabold text-gray-900" id="offlineMessage">You're offline</p>
                <p class="text-xs text-gray-500" id="offlineSubMessage">Using cached data</p>
            </div>
        </div>
    </div>
</div>

<script>
    const indicator = document.getElementById('offlineIndicator');
    const message = document.getElementById('offlineMessage');
    const subMessage = document.getElementById('offlineSubMessage');
    const statusPill = document.getElementById('offlineStatusPill');
    let hideTimeout: number;

    function showIndicator() {
        if (indicator) {
            indicator.classList.remove('translate-y-full', 'opacity-0');
        }
    }

    function hideIndicator() {
        if (indicator) {
            indicator.classList.add('translate-y-full', 'opacity-0');
        }
    }

    function updateOfflineStatus(online: boolean) {
        // Clear any existing timeout
        if (hideTimeout) {
            clearTimeout(hideTimeout);
        }

        if (!online) {
            if (message) message.textContent = "You're offline";
            if (subMessage) subMessage.textContent = 'Using cached data';
            if (statusPill) {
                statusPill.textContent = 'Offline';
                statusPill.classList.remove('pill-emerald');
                statusPill.classList.add('pill-amber');
            }
            showIndicator();
        } else {
            if (message) message.textContent = 'Back online';
            if (subMessage) subMessage.textContent = 'Updating with latest data…';
            if (statusPill) {
                statusPill.textContent = 'Online';
                statusPill.classList.remove('pill-amber');
                statusPill.classList.add('pill-emerald');
            }
            showIndicator();

            // Hide after 3 seconds
            hideTimeout = window.setTimeout(() => {
                hideIndicator();
            }, 3000);
        }
    }

    // Listen for online/offline events
    window.addEventListener('online', () => updateOfflineStatus(true));
    window.addEventListener('offline', () => updateOfflineStatus(false));

    // Initial check - hide by default unless offline
    if (!navigator.onLine) {
        updateOfflineStatus(false);
    } else {
        hideIndicator();
    }

    // Cleanup on component unmount
    document.addEventListener('astro:before-swap', () => {
        if (hideTimeout) {
            clearTimeout(hideTimeout);
        }
    });
</script>
