---
import type { Event } from '@service/core/supabase/shared/types.ts';

interface Props {
    event: Event;
}

const { event } = Astro.props;
---

<button
    data-event-id={event.id}
    data-event-slug={event.slug}
    data-event-cover-photo={event.cover_photo}
    data-event-name={event.name}
    data-event-date={event.start_time}
    data-event-location={event.location}
    class="save-event-btn press-sm shadow-soft-1 flex h-10 items-center gap-2 rounded-full bg-white px-4 text-sm font-semibold text-gray-700 transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
    aria-label="Save event"
>
    <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"
        >
        </path>
    </svg>
    <span class="save-text-stack">
        <span class="save-label save-label-default">Save</span>
        <span class="save-label save-label-saved">Saved</span>
    </span>
</button>

<script>
    type SavedEvent = {
        id: string;
        slug: string;
        name: string;
        cover_photo: string;
        start_time: string;
        location: string;
    };

    function applySavedState(button: Element, saved: boolean) {
        const svg = button.querySelector('svg');
        if (saved) {
            button.classList.add('is-saved');
            svg?.classList.add('fill-current');
            button.setAttribute('aria-pressed', 'true');
        } else {
            button.classList.remove('is-saved');
            svg?.classList.remove('fill-current');
            button.setAttribute('aria-pressed', 'false');
        }
    }

    function initializeSaveButtons() {
        // Get all save buttons on the page
        const saveButtons = document.querySelectorAll('.save-event-btn');

        // Get saved events from localStorage
        const savedEvents: SavedEvent[] = JSON.parse(localStorage.getItem('savedEvents') || '[]');

        saveButtons.forEach((button) => {
            const eventId = button.getAttribute('data-event-id')!;
            const eventSlug = button.getAttribute('data-event-slug')!;
            const eventCoverPhoto = button.getAttribute('data-event-cover-photo')!;
            const eventName = button.getAttribute('data-event-name')!;
            const eventDate = button.getAttribute('data-event-date')!;
            const eventLocation = button.getAttribute('data-event-location')!;

            // Check if event is already saved
            const isSaved = savedEvents.some((event) => event.id === eventId);
            applySavedState(button, isSaved);

            // Add click handler
            button.addEventListener('click', async () => {
                const savedEvents: SavedEvent[] = JSON.parse(localStorage.getItem('savedEvents') || '[]');
                const isSaved = savedEvents.some((event) => event.id === eventId);

                if (isSaved) {
                    if (typeof window !== 'undefined' && window.umami) {
                        window.umami.track('event_unsave', {
                            event_id: eventId,
                            event_name: eventName,
                            event_location: eventLocation
                        });
                    }
                    const updatedEvents = savedEvents.filter((event) => event.id !== eventId);
                    localStorage.setItem('savedEvents', JSON.stringify(updatedEvents));
                    applySavedState(button, false);
                } else {
                    if (typeof window !== 'undefined' && window.umami) {
                        window.umami.track('event_save', {
                            event_id: eventId,
                            event_name: eventName,
                            event_location: eventLocation
                        });
                    }
                    // Use the rendered (Astro-optimized) URL so /saved hits the
                    // browser cache on back-nav and the IMG paints during VT capture.
                    const renderedCover = document.querySelector(
                        `img[data-cover-id="${eventId}"]`
                    ) as HTMLImageElement | null;
                    const coverPhoto = renderedCover?.src || eventCoverPhoto;
                    const eventDetails = {
                        id: eventId,
                        slug: eventSlug,
                        cover_photo: coverPhoto,
                        name: eventName,
                        start_time: eventDate,
                        location: eventLocation,
                    };
                    savedEvents.push(eventDetails);
                    localStorage.setItem('savedEvents', JSON.stringify(savedEvents));
                    applySavedState(button, true);
                    // Delight: pop the bookmark icon once on save
                    const icon = button.querySelector('svg');
                    if (icon) {
                        icon.classList.remove('pop-once');
                        // Force reflow so the animation re-triggers on rapid taps
                        void (icon as SVGElement).getBoundingClientRect();
                        icon.classList.add('pop-once');
                        setTimeout(() => icon.classList.remove('pop-once'), 400);
                    }
                }

                // Dispatch storage event for other tabs
                window.dispatchEvent(new Event('storage'));
            });
        });
    }

    // Initialize on page load
    document.addEventListener('DOMContentLoaded', initializeSaveButtons);
</script>

<style>
    .save-event-btn.is-saved {
        background: linear-gradient(180deg, #c084fc 0%, #9333ea 100%);
        color: white;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.4),
            inset 0 -1px 0 rgba(0, 0, 0, 0.15),
            0 1px 2px rgba(80, 20, 160, 0.25),
            0 4px 12px rgba(147, 51, 234, 0.35);
    }

    /* Layered labels — the longer "Saved" reserves layout width via the
       invisible ::before so the button doesn't shift on toggle. */
    .save-text-stack {
        position: relative;
        display: inline-block;
        line-height: 1;
    }
    .save-text-stack::before {
        content: 'Saved';
        visibility: hidden;
    }
    .save-label {
        position: absolute;
        inset: 0;
        transition: opacity 140ms cubic-bezier(0.2, 0, 0, 1);
    }
    .save-label-saved {
        opacity: 0;
    }
    .save-event-btn.is-saved .save-label-default {
        opacity: 0;
    }
    .save-event-btn.is-saved .save-label-saved {
        opacity: 1;
    }
    @media (prefers-reduced-motion: reduce) {
        .save-label {
            transition: none;
        }
    }
    @media (hover: hover) and (pointer: fine) {
        .save-event-btn.is-saved:hover {
            background: linear-gradient(180deg, #d8b4fe 0%, #a855f7 100%);
            box-shadow:
                inset 0 1px 0 rgba(255, 255, 255, 0.5),
                inset 0 -1px 0 rgba(0, 0, 0, 0.15),
                0 2px 4px rgba(80, 20, 160, 0.3),
                0 6px 16px rgba(147, 51, 234, 0.4);
        }
    }
</style>
