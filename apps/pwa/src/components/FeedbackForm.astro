---
// Centered feedback modal. Mount once globally (see Layout.astro). Any element
// with `data-open-feedback` opens it — e.g. a footer link, an FAQ "tell us"
// nudge, or an empty-state copy line. The trigger is intentionally not part of
// this component so triggers can sit contextually wherever they fit.
---

<div
    id="feedback-modal"
    class="feedback-modal fixed inset-0 z-[100] flex items-center justify-center p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="feedback-title"
    aria-hidden="true"
>
    <div class="feedback-backdrop fixed inset-0 bg-stone-900/30 backdrop-blur-sm" data-feedback-close></div>

    <div class="feedback-panel card-tactile relative w-full max-w-md p-6">
        <div class="mb-4 flex items-start justify-between gap-3">
            <h2 id="feedback-title" class="text-lg font-extrabold text-gray-900">Send feedback</h2>
            <button
                type="button"
                data-feedback-close
                class="press-sm shadow-soft-1 -mr-1 -mt-1 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-white text-gray-500 transition-colors hover:text-purple-700"
                aria-label="Close"
            >
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"
                    ></path>
                </svg>
            </button>
        </div>

        <p id="feedback-description" class="mb-4 text-sm text-gray-500">
            Spotted a bug, missing event, or have an idea? Tell us — we read every one.
        </p>

        <form id="feedback-form" class="space-y-4">
            <input type="hidden" id="feedback-category" name="category" value="general" />
            <div id="feedback-kind" class="hidden"></div>
            <div>
                <label
                    for="feedback-message"
                    class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gray-600"
                >
                    What's on your mind
                </label>
                <textarea
                    id="feedback-message"
                    name="message"
                    rows="4"
                    required
                    class="feedback-input w-full resize-none px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400"
                    placeholder="Thoughts, suggestions, or what broke…"></textarea>
            </div>
            <div>
                <label
                    for="feedback-email"
                    class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gray-600"
                >
                    Email <span class="font-normal normal-case text-gray-400"
                        >(optional — only if you want a reply)</span
                    >
                </label>
                <input
                    type="email"
                    id="feedback-email"
                    name="email"
                    class="feedback-input w-full px-3.5 py-2.5 text-sm text-gray-900 placeholder:text-gray-400"
                    placeholder="you@example.com"
                />
            </div>

            <div id="feedback-status" class="hidden" aria-live="polite"></div>

            <div class="flex items-center justify-end gap-2 pt-1">
                <button type="button" data-feedback-close class="press-sm chip-tactile chip-inactive !text-[13px]">
                    Cancel
                </button>
                <button type="submit" id="feedback-submit" class="press-sm btn-primary-tactile">
                    <span id="feedback-submit-label">Send</span>
                    <svg
                        id="feedback-spinner"
                        class="!hidden h-3.5 w-3.5 animate-spin"
                        viewBox="0 0 24 24"
                        fill="none"
                        aria-hidden="true"
                    >
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"
                        ></circle>
                        <path
                            class="opacity-75"
                            fill="currentColor"
                            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                        ></path>
                    </svg>
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .feedback-modal {
        opacity: 0;
        pointer-events: none;
        transition:
            opacity 200ms cubic-bezier(0.2, 0, 0, 1),
            visibility 200ms;
        visibility: hidden;
    }
    .feedback-modal.is-open {
        opacity: 1;
        pointer-events: auto;
        visibility: visible;
    }

    .feedback-panel {
        transform: scale(0.96) translateY(8px);
        transition: transform 220ms cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .feedback-modal.is-open .feedback-panel {
        transform: scale(1) translateY(0);
    }

    .feedback-input {
        background: linear-gradient(180deg, #ffffff 0%, #fafaf9 100%);
        border-radius: 14px;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 1),
            inset 0 0 0 1px rgba(15, 15, 15, 0.08),
            0 1px 2px rgba(15, 15, 15, 0.03);
        transition: box-shadow 160ms cubic-bezier(0.2, 0, 0, 1);
    }
    .feedback-input:focus {
        outline: none;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 1),
            inset 0 0 0 2px rgba(147, 51, 234, 0.5),
            0 1px 2px rgba(147, 51, 234, 0.12),
            0 4px 12px rgba(147, 51, 234, 0.12);
    }

    @media (prefers-reduced-motion: reduce) {
        .feedback-modal,
        .feedback-panel {
            transition: none;
        }
    }
</style>

<script>
    const modal = document.getElementById('feedback-modal');
    const form = document.getElementById('feedback-form') as HTMLFormElement | null;
    const messageInput = document.getElementById('feedback-message') as HTMLTextAreaElement | null;
    const categoryInput = document.getElementById('feedback-category') as HTMLInputElement | null;
    const categoryBadge = document.getElementById('feedback-kind');
    const titleEl = document.getElementById('feedback-title');
    const descriptionEl = document.getElementById('feedback-description');
    const submitBtn = document.getElementById('feedback-submit') as HTMLButtonElement | null;
    const submitLabel = document.getElementById('feedback-submit-label');
    const spinner = document.getElementById('feedback-spinner');
    const status = document.getElementById('feedback-status');

    let lastFocused: HTMLElement | null = null;
    let feedbackContext: Record<string, string | number | undefined> = {};
    const defaultTitle = 'Send feedback';
    const defaultDescription = 'Spotted a bug, missing event, or have an idea? Tell us — we read every one.';
    const defaultPlaceholder = 'Thoughts, suggestions, or what broke…';
    const categoryLabels: Record<string, string> = {
        wrong_date: 'Wrong date',
        wrong_location: 'Wrong location',
        cancelled: 'Event cancelled',
        bad_source: 'Bad source',
        duplicate: 'Duplicate event',
        general: 'General feedback',
    };

    function compactText(value: string | null | undefined) {
        return value?.replace(/\s+/g, ' ').trim() || undefined;
    }

    function getFeedbackContext(trigger?: Element | null) {
        const url = new URL(window.location.href);
        const eventSlug = url.pathname.match(/^\/events\/([^/?#]+)/)?.[1];
        const pageHeading = compactText(document.querySelector('h1')?.textContent);
        const pageTitle = compactText(document.title);
        const feedbackCategory = trigger?.getAttribute('data-feedback-category') || 'general';

        return {
            pageUrl: window.location.href,
            pagePath: `${url.pathname}${url.search}`,
            pageTitle,
            eventSlug,
            eventTitle: eventSlug ? pageHeading || pageTitle?.replace(/\s+-\s+cebby$/i, '') : undefined,
            feedbackCategory,
            triggerLabel: compactText(trigger?.textContent),
            referrer: document.referrer || undefined,
            viewport: `${window.innerWidth}x${window.innerHeight}`,
            devicePixelRatio: window.devicePixelRatio,
            language: navigator.language,
            timezone: Intl.DateTimeFormat().resolvedOptions().timeZone,
            userAgent: navigator.userAgent,
        };
    }

    function open(trigger?: Element | null) {
        if (!modal) return;
        feedbackContext = getFeedbackContext(trigger);
        const category = String(feedbackContext.feedbackCategory || 'general');
        const label = categoryLabels[category] || categoryLabels.general;
        const prompt = trigger?.getAttribute('data-feedback-prompt') || defaultPlaceholder;

        if (categoryInput) categoryInput.value = category;
        if (titleEl) titleEl.textContent = category === 'general' ? defaultTitle : 'Report event issue';
        if (descriptionEl) {
            descriptionEl.textContent =
                category === 'general'
                    ? defaultDescription
                    : 'Send the correction signal. Source links or exact details help us fix it faster.';
        }
        if (categoryBadge) {
            categoryBadge.className =
                category === 'general'
                    ? 'hidden'
                    : 'pill-tactile pill-amber inline-flex w-fit !text-[13px]';
            categoryBadge.textContent = label;
        }
        if (messageInput) messageInput.placeholder = prompt;

        lastFocused = document.activeElement as HTMLElement;
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        // Focus the textarea after the panel finishes its entrance
        setTimeout(() => messageInput?.focus(), 120);
    }

    function close() {
        if (!modal) return;
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (titleEl) titleEl.textContent = defaultTitle;
        if (descriptionEl) descriptionEl.textContent = defaultDescription;
        if (categoryInput) categoryInput.value = 'general';
        if (categoryBadge) {
            categoryBadge.className = 'hidden';
            categoryBadge.textContent = '';
        }
        if (messageInput) messageInput.placeholder = defaultPlaceholder;
        if (status) {
            status.classList.add('hidden');
            status.textContent = '';
            status.className = 'hidden';
        }
        lastFocused?.focus();
    }

    function setStatus(kind: 'success' | 'error', text: string) {
        if (!status) return;
        status.textContent = text;
        status.className =
            kind === 'success'
                ? 'pill-tactile pill-emerald w-full justify-center !text-[13px]'
                : 'pill-tactile pill-rose w-full justify-center !text-[13px]';
    }

    // Open from any [data-open-feedback] element
    document.addEventListener('click', (e) => {
        const trigger = (e.target as HTMLElement)?.closest('[data-open-feedback]');
        if (trigger) {
            e.preventDefault();
            open(trigger);
            return;
        }
        const closer = (e.target as HTMLElement)?.closest('[data-feedback-close]');
        if (closer) {
            e.preventDefault();
            close();
        }
    });

    // Escape closes
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal?.classList.contains('is-open')) close();
    });

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!submitBtn || !submitLabel || !spinner) return;
        const data = new FormData(form);
        const message = String(data.get('message') || '').trim();
        const email = String(data.get('email') || '').trim();
        const category = String(data.get('category') || feedbackContext.feedbackCategory || 'general');

        submitBtn.disabled = true;
        submitLabel.textContent = 'Sending';
        spinner.classList.remove('!hidden');

        try {
            const res = await fetch('/api/feedback', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    message,
                    email: email || undefined,
                    category,
                    context: feedbackContext || getFeedbackContext(),
                }),
            });
            if (!res.ok) throw new Error('submit-failed');
            setStatus('success', 'Thanks — we got it. We read every one.');
            form.reset();
            setTimeout(close, 1600);
        } catch (err) {
            console.error('feedback submit failed', err);
            setStatus('error', "Couldn't send — try again in a moment?");
        } finally {
            submitBtn.disabled = false;
            submitLabel.textContent = 'Send';
            spinner.classList.add('!hidden');
        }
    });
</script>
