---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
import BottomTabDock from '../components/BottomTabDock.astro';
import EventCard from '../components/EventCard.astro';
import MapView from '../components/MapView.astro';
import SEO from '../components/SEO.astro';
import type { EventFromDB } from '../types/database';
import type { GroupedEvents } from '../utils/events';

// Set cache headers for the page
Astro.response.headers.set('Cache-Control', 'public, s-maxage=300, max-age=300, stale-while-revalidate=60');
Astro.response.headers.set('CDN-Cache-Control', 'max-age=300');

// Fetch events from cached API endpoint
let events: GroupedEvents | null = null;
let allEvents: EventFromDB[] | null = null;
let allUpcomingEvents: EventFromDB[] = [];
let error: any = null;
let upcomingCount = 0;
let totalEvents = 0;

try {
    const apiUrl = new URL('/api/events-data', Astro.url);
    apiUrl.searchParams.set('cache', '5');
    const response = await fetch(apiUrl.toString());
    if (!response.ok) throw new Error(`Failed to fetch events: ${response.status}`);

    const data = await response.json();
    events = data.events;
    allEvents = data.allEvents;
    allUpcomingEvents = data.allUpcomingEvents || [];
    upcomingCount = data.metrics?.upcomingCount || 0;
    totalEvents = data.metrics?.totalEvents || 0;
} catch (err) {
    console.error('Error fetching events:', err);
    error = err;
    events = {
        happening: [],
        today: [],
        tomorrow: [],
        thisWeek: [],
        nextWeek: [],
        thisMonth: [],
        nextMonth: [],
        later: [],
        recent: [],
        past: [],
    };
}

const {
    happening: happeningEvents = [],
    today: todayEvents = [],
    tomorrow: tomorrowEvents = [],
    thisWeek: thisWeekEvents = [],
    nextWeek: nextWeekEvents = [],
    thisMonth: thisMonthEvents = [],
    nextMonth: nextMonthEvents = [],
    later: laterEvents = [],
    recent: recentEvents = [],
} = events ?? {};

const thisWeek: EventFromDB[] = [...todayEvents, ...tomorrowEvents, ...thisWeekEvents];
const comingUp: EventFromDB[] = [...nextWeekEvents, ...thisMonthEvents, ...nextMonthEvents, ...laterEvents];
const past: EventFromDB[] = recentEvents.slice(0, 6);

const thisWeekCount = thisWeek.length;
const comingUpCount = comingUp.length;
const isQuietWeek = thisWeekCount === 0 && comingUpCount === 0 && happeningEvents.length === 0;

// Map view: prefer upcoming events. If there are none (empty-week state),
// fall back to recent events so the map still answers "where do things happen?"
const mapEvents: EventFromDB[] =
    allUpcomingEvents.length > 0 ? allUpcomingEvents : recentEvents;

// Compute filter tags per event from keywords in name/description/location.
// This is a v1 heuristic — proper tagging system comes with the future tag-follow feature.
function tagsFor(event: EventFromDB): string {
    const haystack = [event.name, event.description, event.location].filter(Boolean).join(' ').toLowerCase();
    const tags: string[] = [];
    if (/\bfree\b|no fee|no cost|no charge|complimentary/.test(haystack)) tags.push('free');
    if (/beginner|intro|introduction|getting started|101|fundamentals|newbie|starter/.test(haystack)) tags.push('beginner');
    return tags.join(' ');
}

// Range label for "this week"
function fmtMonthDay(d: Date) {
    return d.toLocaleString('default', { month: 'short', day: 'numeric' });
}
const today = new Date();
const weekEnd = new Date();
weekEnd.setDate(today.getDate() + 6);
const rangeLabel = `${fmtMonthDay(today)} – ${fmtMonthDay(weekEnd)}`;

const homeJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Discover all tech events in Cebu in one place - cebby',
    description: 'Discover the latest tech events, conferences, workshops, and meetups happening in Cebu.',
    publisher: {
        '@type': 'Organization',
        name: 'Cebby',
        logo: {
            '@type': 'ImageObject',
            url: new URL('/icons/icon-512x512.png', Astro.url),
        },
    },
    mainEntity: {
        '@type': 'ItemList',
        itemListElement: allUpcomingEvents?.map((event: EventFromDB, index: number) => ({
            '@type': 'ListItem',
            position: index + 1,
            item: {
                '@type': 'Event',
                name: event.name,
                startDate: event.start_time,
                location: { '@type': 'Place', name: event.location },
                url: new URL(`/events/${event?.slug || event?.id}`, Astro.url),
            },
        })),
    },
};

const metaDescription = `Discover ${upcomingCount} upcoming and ${totalEvents} total tech events in Cebu. Find workshops, conferences, meetups, and more tech-related events.`;
---

<Layout title="Discover all tech events in Cebu in one place - cebby">
    <Fragment slot="head">
        <SEO
            title="Discover all tech events in Cebu in one place - cebby"
            description={metaDescription}
            image="/screenshots/image2.png"
            type="website"
        />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(homeJsonLd)} />
    </Fragment>

    <AppHeader />

    <main class="mx-auto max-w-2xl px-5 pb-32 pt-2">
        {
            error && (
                <div
                    class="mb-6 rounded-2xl border border-red-200 bg-red-50 px-5 py-4 text-sm text-red-700"
                    role="alert"
                >
                    Failed to load events. Please try again later.
                </div>
            )
        }

        {/* Hero stats */}
        <section class="mb-8">
            <div class="mb-4 flex items-baseline justify-between">
                <h1 class="text-xl font-bold text-gray-900">This week in Cebu tech</h1>
                <span class="text-xs font-medium text-gray-500">{rangeLabel}</span>
            </div>
            {
                isQuietWeek ? (
                    <div class="card-tactile flex items-center gap-3 p-4">
                        <span class="relative flex h-2 w-2 flex-shrink-0">
                            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-purple-300 opacity-75" />
                            <span class="relative inline-flex h-2 w-2 rounded-full bg-purple-500" />
                        </span>
                        <div class="text-sm text-gray-600">
                            <span class="font-semibold text-gray-900">Quiet week.</span>{' '}
                            We check sources every few hours — new events show up here automatically.
                        </div>
                    </div>
                ) : (
                    <div class="grid grid-cols-2 gap-3">
                        <div class="entrance-pop card-tactile p-5">
                            <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">
                                This week
                            </div>
                            <div class="mb-2 text-4xl font-extrabold leading-none text-gray-900">
                                {thisWeekCount}
                            </div>
                            <div class="text-xs font-medium text-gray-500">
                                {thisWeekCount === 1 ? 'event' : 'events'}
                            </div>
                        </div>
                        <div class="entrance-pop card-tactile p-5" style="animation-delay: 80ms">
                            <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">
                                Coming up
                            </div>
                            <div class="mb-2 text-4xl font-extrabold leading-none text-gray-900">
                                {comingUpCount}
                            </div>
                            <div class="text-xs font-medium text-gray-500">later events</div>
                        </div>
                    </div>
                )
            }
        </section>

        {/* View toggle */}
        <section class="mb-5" aria-label="View">
            <div
                id="view-toggle"
                class="inline-flex rounded-full bg-gray-100 p-1 ring-1 ring-gray-200"
                role="tablist"
                aria-label="Switch between list and map view"
            >
                <button
                    type="button"
                    class="press-sm view-toggle-btn view-toggle-active"
                    data-view="list"
                    role="tab"
                    aria-selected="true"
                >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <line x1="8" y1="6" x2="21" y2="6"/>
                        <line x1="8" y1="12" x2="21" y2="12"/>
                        <line x1="8" y1="18" x2="21" y2="18"/>
                        <line x1="3" y1="6" x2="3.01" y2="6"/>
                        <line x1="3" y1="12" x2="3.01" y2="12"/>
                        <line x1="3" y1="18" x2="3.01" y2="18"/>
                    </svg>
                    List
                </button>
                <button
                    type="button"
                    class="press-sm view-toggle-btn view-toggle-inactive"
                    data-view="map"
                    role="tab"
                    aria-selected="false"
                >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                    </svg>
                    Map
                </button>
            </div>
        </section>

        {/* Map view (toggled) */}
        <section id="map-view-section" class="mb-10 hidden" aria-label="Map view">
            {allUpcomingEvents.length === 0 && mapEvents.length > 0 && (
                <div class="mb-3 rounded-2xl bg-purple-50 px-4 py-3 text-sm text-purple-900 ring-1 ring-purple-100">
                    <span class="font-semibold">No upcoming events this week</span> — here's where Cebu tech usually meets.
                </div>
            )}
            <MapView events={mapEvents} />
        </section>

        {/* Filter chips */}
        <section class="mb-8" data-list-only aria-label="Filters">
            <div id="filter-chips" class="flex flex-wrap gap-2.5">
                <button class="press-sm entrance-rise chip-tactile chip-active" data-filter="all" aria-pressed="true">All</button>
                <button class="press-sm entrance-rise chip-tactile chip-inactive" data-filter="this-week" aria-pressed="false" style="animation-delay: 60ms">This week</button>
                <button class="press-sm entrance-rise chip-tactile chip-inactive" data-filter="free" aria-pressed="false" style="animation-delay: 120ms">Free</button>
                <button class="press-sm entrance-rise chip-tactile chip-inactive" data-filter="beginner" aria-pressed="false" style="animation-delay: 180ms">Beginner</button>
            </div>
        </section>

        {/* Happening now */}
        {
            happeningEvents.length > 0 && (
                <section class="mb-10" data-section="happening" data-bucket="this-week">
                    <h2 class="mb-4 flex items-center gap-2 text-xl font-bold text-gray-900">
                        <span class="relative flex h-2.5 w-2.5">
                            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-rose-400 opacity-75" />
                            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-rose-500" />
                        </span>
                        Happening now
                    </h2>
                    <div class="space-y-5">
                        {happeningEvents.map((event: EventFromDB) => (
                            <div data-event-tags={tagsFor(event)}>
                                <EventCard event={event} variant="upcoming" />
                            </div>
                        ))}
                    </div>
                </section>
            )
        }

        {/* This week */}
        {
            thisWeek.length > 0 && (
                <section class="mb-10" data-section="this-week" data-bucket="this-week">
                    <h2 class="mb-4 text-xl font-bold text-gray-900">This week</h2>
                    <div class="space-y-5">
                        {thisWeek.map((event: EventFromDB) => (
                            <div data-event-tags={tagsFor(event)}>
                                <EventCard event={event} variant="upcoming" />
                            </div>
                        ))}
                    </div>
                </section>
            )
        }

        {/* Coming up */}
        {
            comingUp.length > 0 && (
                <section class="mb-10" data-section="coming-up" data-bucket="later">
                    <h2 class="mb-4 text-xl font-bold text-gray-900">Coming up</h2>
                    <div class="space-y-5">
                        {comingUp.map((event: EventFromDB) => (
                            <div data-event-tags={tagsFor(event)}>
                                <EventCard event={event} variant="upcoming" />
                            </div>
                        ))}
                    </div>
                </section>
            )
        }

        {/* Empty state — only when there's truly nothing to show (no upcoming AND no past). */}
        {
            isQuietWeek && past.length === 0 && (
                <section class="mb-10" data-list-only>
                    <div class="card-tactile p-8 text-center">
                        <div class="mb-2 text-base font-extrabold text-gray-900">
                            Nothing tracked yet
                        </div>
                        <p class="text-sm text-gray-500">
                            We're checking sources every few hours. Subscribe to the calendar so events show up
                            automatically when they appear.
                        </p>
                    </div>
                </section>
            )
        }

        {/* Past events */}
        {
            past.length > 0 && (
                <section class="mb-10" data-section="recent" data-bucket="past">
                    <h2 class="mb-1 text-xl font-bold text-gray-900">Past events</h2>
                    <p class="mb-4 text-sm text-gray-500">
                        {isQuietWeek ? 'While we wait for the next one — what just wrapped:' : 'What recently happened in the Cebu tech scene.'}
                    </p>
                    <div class="space-y-5">
                        {past.map((event: EventFromDB) => (
                            <div data-event-tags={tagsFor(event)}>
                                <EventCard event={event} variant="recent" />
                            </div>
                        ))}
                    </div>
                </section>
            )
        }

        {/* Calendar subscribe nudge */}
        <section class="mt-12">
            <div class="card-tactile flex items-center gap-4 p-5">
                <div
                    class="date-chip date-chip-purple flex h-12 w-12 flex-shrink-0 items-center justify-center"
                    style="padding: 0"
                >
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="text-purple-700">
                        <path
                            d="M3 8h16M5 4h12a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2zM7 2v4M15 2v4"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                        ></path>
                    </svg>
                </div>
                <div class="min-w-0 flex-1">
                    <div class="text-sm font-extrabold text-gray-900">
                        Never miss a Cebu tech event
                    </div>
                    <div class="mt-0.5 text-xs text-gray-500">
                        Subscribe once, all events appear in your calendar.
                    </div>
                </div>
                <a href="/calendar" class="press-sm btn-primary-tactile flex-shrink-0">
                    Subscribe
                </a>
            </div>
        </section>
    </main>

    <BottomTabDock active="events" />
</Layout>

<script>
    const chips = document.querySelectorAll<HTMLButtonElement>('#filter-chips [data-filter]');
    const sections = document.querySelectorAll<HTMLElement>('[data-section]');

    function applyFilter(filter: string) {
        sections.forEach((section) => {
            const bucket = section.getAttribute('data-bucket') ?? '';
            const isTimeBucket = filter === 'this-week';
            const isTagFilter = filter === 'free' || filter === 'beginner';

            // Hide entire section if it's a "later" bucket and filter is "this-week"
            if (isTimeBucket && bucket !== 'this-week') {
                section.classList.add('hidden');
                return;
            }

            section.classList.remove('hidden');

            // Per-card tag filtering
            const cards = section.querySelectorAll<HTMLElement>('[data-event-tags]');
            let visibleInSection = 0;
            cards.forEach((card) => {
                const tags = (card.getAttribute('data-event-tags') ?? '').split(' ');
                const matches = filter === 'all' || isTimeBucket || (isTagFilter && tags.includes(filter));
                card.classList.toggle('hidden', !matches);
                if (matches) visibleInSection += 1;
            });

            // If no card matches in this section, hide the whole section heading
            if (isTagFilter && visibleInSection === 0) {
                section.classList.add('hidden');
            }
        });
    }

    chips.forEach((chip) => {
        chip.addEventListener('click', () => {
            const filter = chip.getAttribute('data-filter') ?? 'all';
            chips.forEach((c) => {
                const isActive = c === chip;
                c.classList.toggle('chip-active', isActive);
                c.classList.toggle('chip-inactive', !isActive);
                c.setAttribute('aria-pressed', String(isActive));
            });
            // Delight: pop the newly active chip
            chip.classList.remove('chip-pop-once');
            void chip.getBoundingClientRect();
            chip.classList.add('chip-pop-once');
            setTimeout(() => chip.classList.remove('chip-pop-once'), 280);
            applyFilter(filter);
        });
    });

    // ---- View toggle: list ↔ map ----
    const VIEW_KEY = 'cebbyEventsView';
    const viewToggle = document.getElementById('view-toggle');
    const viewButtons = viewToggle?.querySelectorAll<HTMLButtonElement>('[data-view]') ?? [];
    const mapSection = document.getElementById('map-view-section');
    const listOnlyEls = document.querySelectorAll<HTMLElement>('[data-section], [data-list-only]');

    function applyView(view: 'list' | 'map') {
        const isMap = view === 'map';
        listOnlyEls.forEach((el) => el.classList.toggle('hidden', isMap));
        mapSection?.classList.toggle('hidden', !isMap);

        viewButtons.forEach((btn) => {
            const isActive = btn.getAttribute('data-view') === view;
            btn.classList.toggle('view-toggle-active', isActive);
            btn.classList.toggle('view-toggle-inactive', !isActive);
            btn.setAttribute('aria-selected', String(isActive));
        });

        if (isMap) {
            const root = mapSection?.querySelector<HTMLElement>('[data-mapview-root]');
            const init = (window as any).__cebbyInitMapView;
            if (root && typeof init === 'function') init(root);
        }
    }

    const initialView = (() => {
        try {
            return localStorage.getItem(VIEW_KEY) === 'map' ? 'map' : 'list';
        } catch {
            return 'list';
        }
    })();
    applyView(initialView);

    viewButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
            const view = (btn.getAttribute('data-view') as 'list' | 'map') ?? 'list';
            try { localStorage.setItem(VIEW_KEY, view); } catch {}
            applyView(view);
        });
    });
</script>

<style>
    .view-toggle-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        font-size: 0.8125rem;
        font-weight: 600;
        transition: background 160ms ease, color 160ms ease, box-shadow 160ms ease;
    }
    .view-toggle-active {
        background: white;
        color: rgb(17, 24, 39);
        box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06), 0 1px 1px rgba(0, 0, 0, 0.04);
    }
    .view-toggle-inactive {
        background: transparent;
        color: rgb(75, 85, 99);
    }
    .view-toggle-inactive:hover {
        color: rgb(17, 24, 39);
    }
</style>
