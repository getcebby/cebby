    /* Subscribe-card → /calendar morph: gated by viewport visibility.
       Long-distance morphs from below-fold to the target page's position
       read as "card flying up from nowhere" — applying view-transition-name
       only when the source is on-screen at click time keeps the in-place
       morph (when scrolled to the card) and degrades gracefully to a quiet
       fade-in at the target (when scrolled past the card). */
    #subscribe-card-host[data-vt-active] .vt-surface  { view-transition-name: subscribe-card-surface;  }
    #subscribe-card-host[data-vt-active] .vt-icon     { view-transition-name: subscribe-card-icon;     }
    #subscribe-card-host[data-vt-active] .vt-headline { view-transition-name: subscribe-card-headline; }
    #subscribe-card-host[data-vt-active] .vt-subline  { view-transition-name: subscribe-card-subline;  }
</style>

<script is:inline>
    // Viewport-gated VT names — see CSS comment above.
    (() => {
        const host = document.getElementById('subscribe-card-host');
        if (!host) return;
        const sync = () => {
            const r = host.getBoundingClientRect();
            const inView = r.top < window.innerHeight && r.bottom > 0;
            host.toggleAttribute('data-vt-active', inView);
        };
        // Set initial state synchronously so the VT capture on initial
        // pagereveal sees the right state.
        sync();
        // Track scroll changes via IntersectionObserver (cheap, passive).
        const obs = new IntersectionObserver((entries) => {
            host.toggleAttribute('data-vt-active', !!entries[0]?.isIntersecting);
        }, { threshold: 0.01 });
        obs.observe(host);
        // Re-sync just before any cross-doc VT capture in case the
        // observer hasn't settled yet at click time.
        window.addEventListener('pagehide', sync);
    })();
</script>
