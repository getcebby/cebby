---
import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
---

<Layout title="Not found — cebby">
    <AppHeader showSearch={false} />
    <main class="mx-auto max-w-2xl px-5 pb-20 pt-2">
        <div class="card-tactile p-10 text-center">
            <div class="mb-2 text-3xl font-extrabold text-gray-900">404</div>
            <p class="mb-6 text-sm text-gray-500">
                We couldn't find that page. It may have moved, or it never existed.
            </p>
            <a href="/events" class="press-sm btn-primary-tactile inline-flex">
                Back to events
            </a>
        </div>
        <p class="mt-6 text-center text-sm text-gray-500">
            Hit a dead link?{' '}
            <button
                type="button"
                data-open-feedback
                class="font-semibold text-gray-700 underline-offset-4 transition-colors hover:text-purple-700 hover:underline"
            >
                Tell us where you came from
            </button>
        </p>
    </main>
</Layout>
