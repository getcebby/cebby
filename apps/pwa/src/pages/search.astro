---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
import BottomTabDock from '../components/BottomTabDock.astro';
import SEO from '../components/SEO.astro';
import { searchEvents } from '../lib/typesense';
import type { EventDocument } from '../lib/typesense';

const url = new URL(Astro.request.url);
const query = url.searchParams.get('q') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 20;

let searchResults: EventDocument[] = [];
let totalFound = 0;
let searchTimeMs = 0;
let searchError: string | null = null;

if (query.trim()) {
    try {
        const results = await searchEvents(query, { per_page: perPage, page });
        searchResults = results.results as EventDocument[];
        totalFound = results.found;
        searchTimeMs = results.search_time_ms ?? 0;
        searchError = results.error || null;
    } catch (e) {
        console.error('Search error:', e);
        searchError = 'Search service unavailable';
    }
}

const totalPages = Math.ceil(totalFound / perPage);
const hasNextPage = page < totalPages;
const hasPrevPage = page > 1;

function buildPageUrl(p: number) {
    const u = new URL(Astro.request.url);
    u.searchParams.set('page', String(p));
    return u.pathname + '?' + u.searchParams.toString();
}

const metaDescription = query
    ? `Search results for "${query}" - Found ${totalFound} events in Cebu's tech community`
    : "Search through Cebu's tech events, conferences, workshops, and meetups";
---

<Layout title={query ? `Search: ${query} — cebby` : 'Search — cebby'}>
    <Fragment slot="head">
        <SEO
            title={query ? `Search: ${query} — cebby` : 'Search Events — cebby'}
            description={metaDescription}
            image="/screenshots/image2.png"
            type="website"
        />
    </Fragment>

    <AppHeader showSearch={false} />

    <main class="mx-auto max-w-2xl px-5 pb-32 pt-2">
        {/* Search bar */}
        <form id="search-form" method="get" action="/search" class="mb-6">
            <div id="search-card" class="card-tactile search-card flex items-center gap-3 px-5 py-3">
                <svg
                    id="search-icon"
                    width="18"
                    height="18"
                    viewBox="0 0 18 18"
                    fill="none"
                    class="flex-shrink-0 text-gray-400"
                >
                    <path
                        d="M8 14a6 6 0 100-12 6 6 0 000 12zM16 16l-3.5-3.5"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"></path>
                </svg>
                <input
                    id="search-input"
                    type="search"
                    name="q"
                    value={query}
                    placeholder="Search Cebu tech events…"
                    autofocus
                    autocomplete="off"
                    class="min-w-0 flex-1 bg-transparent text-base font-medium text-gray-900 placeholder-gray-400 focus:outline-none"
                />
                <button
                    id="search-clear"
                    type="button"
                    class:list={[
                        'press-sm flex h-7 w-7 items-center justify-center rounded-full bg-stone-100 text-gray-500 transition-colors duration-150 hover:bg-purple-100 hover:text-purple-700',
                        !query && 'hidden',
                    ]}
                    aria-label="Clear"
                >
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                        <path d="M3 3l8 8M11 3l-8 8" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"
                        ></path>
                    </svg>
                </button>
            </div>
            <div
                id="search-loading"
                class="search-loading-status hidden"
                role="status"
                aria-live="polite"
                aria-atomic="true"
            >
                <span class="search-loading-dot" aria-hidden="true"></span>
                <span>Searching events...</span>
            </div>
        </form>

        {/* Stable container for results — server renders initial state, client swaps on input */}
        <div id="search-results" data-initial-query={query} data-initial-time-ms={String(searchTimeMs)}>
            {/* Results */}
            {
                !query && (
                    <section>
                        <div class="entrance-pop card-tactile p-8 text-center">
                            {/* Magnifying glass — visual anchor for the empty state */}
                            <div
                                class="entrance-pop mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-purple-50 text-purple-600"
                                style="animation-delay: 80ms"
                            >
                                <svg
                                    width="22"
                                    height="22"
                                    viewBox="0 0 22 22"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    aria-hidden="true"
                                >
                                    <circle cx="10" cy="10" r="6" />
                                    <path d="M19 19l-4-4" />
                                </svg>
                            </div>
                            <div
                                class="entrance-rise mb-2 text-base font-extrabold text-gray-900"
                                style="animation-delay: 160ms"
                            >
                                Find an event
                            </div>
                            <p class="entrance-rise text-sm text-gray-500" style="animation-delay: 220ms">
                                Try a keyword, organizer, or topic.
                            </p>
                            <div class="mt-5 flex flex-wrap justify-center gap-2">
                                {['AI', 'hackathon', 'JavaScript', 'startup', 'design'].map((suggestion, i) => (
                                    <button
                                        type="button"
                                        class="press-sm entrance-rise chip-tactile chip-inactive search-suggestion !text-xs transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                                        style={`animation-delay: ${280 + i * 50}ms`}
                                        data-suggestion={suggestion}
                                    >
                                        {suggestion}
                                    </button>
                                ))}
                            </div>
                        </div>
                    </section>
                )
            }

            {
                query && searchError && (
                    <section>
                        <div class="card-tactile p-8 text-center">
                            <div class="mb-2 text-base font-extrabold text-gray-900">Search is taking a break</div>
                            <p class="text-sm text-gray-500">{searchError}. Try again in a bit.</p>
                        </div>
                    </section>
                )
            }

            {
                query && !searchError && totalFound === 0 && (
                    <section>
                        <div class="card-tactile p-8 text-center">
                            <div class="mb-2 text-base font-extrabold text-gray-900">No events match "{query}"</div>
                            <p class="text-sm text-gray-500">Try a broader keyword, or browse all upcoming events.</p>
                            <a href="/events" class="press-sm btn-primary-tactile mt-5 inline-flex">
                                Browse events
                            </a>
                        </div>
                        <p class="mt-6 text-center text-sm text-gray-500">
                            Looking for something we don't have?{' '}
                            <button
                                type="button"
                                data-open-feedback
                                class="font-semibold text-gray-700 underline-offset-4 transition-colors hover:text-purple-700 hover:underline"
                            >
                                Tell us
                            </button>
                        </p>
                    </section>
                )
            }

            {
                query && !searchError && totalFound > 0 && (
                    <>
                        <div class="mb-4 flex items-baseline justify-between">
                            <h1 class="text-xl font-bold text-gray-900">
                                {totalFound} {totalFound === 1 ? 'result' : 'results'}
                                {searchTimeMs > 0 && (
                                    <span class="ml-2 text-xs font-medium text-gray-400">in {searchTimeMs}ms</span>
                                )}
                            </h1>
                            <span class="text-xs font-medium text-gray-500">for "{query}"</span>
                        </div>

                        <div class="space-y-5">
                            {searchResults.map((event) => {
                                const eventDate = new Date(event.start_time * 1000);
                                const day = eventDate.getDate().toString().padStart(2, '0');
                                const month = eventDate.toLocaleString('default', { month: 'short' });
                                const detailUrl = `/events/${event.slug || event.id}`;
                                const timeStr = eventDate.toLocaleString('en-PH', {
                                    weekday: 'short',
                                    month: 'short',
                                    day: 'numeric',
                                    hour: 'numeric',
                                    minute: '2-digit',
                                    hour12: true,
                                });
                                return (
                                    <a
                                        href={detailUrl}
                                        class="press lift-hover card-tactile block overflow-hidden"
                                        data-astro-prefetch="viewport"
                                    >
                                        {event.cover_photo && (
                                            <div class="relative aspect-[16/9] overflow-hidden">
                                                <img
                                                    src={event.cover_photo}
                                                    alt={event.name}
                                                    loading="lazy"
                                                    class="cover-zoom h-full w-full object-cover"
                                                    style={`view-transition-name: event-cover-${event.id}`}
                                                />
                                                <div
                                                    class="date-chip absolute left-4 top-4 text-center"
                                                    style={`view-transition-name: event-date-${event.id}`}
                                                >
                                                    <div class="text-xl font-extrabold leading-none text-gray-900">
                                                        {day}
                                                    </div>
                                                    <div class="mt-1 text-[10px] font-bold uppercase tracking-wider text-gray-500">
                                                        {month}
                                                    </div>
                                                </div>
                                            </div>
                                        )}
                                        <div class="p-5">
                                            {!event.cover_photo && (
                                                <div class="mb-3 flex items-start">
                                                    <div
                                                        class="date-chip date-chip-purple inline-block text-center"
                                                        style={`view-transition-name: event-date-${event.id}`}
                                                    >
                                                        <div class="text-xl font-extrabold leading-none text-purple-900">
                                                            {day}
                                                        </div>
                                                        <div class="mt-1 text-[10px] font-bold uppercase tracking-wider text-purple-700">
                                                            {month}
                                                        </div>
                                                    </div>
                                                </div>
                                            )}
                                            <h3
                                                class="mb-1.5 text-lg font-extrabold leading-snug text-gray-900 line-clamp-2"
                                                style={`view-transition-name: event-title-${event.id}`}
                                            >
                                                {event.name}
                                            </h3>
                                            <p class="text-sm text-gray-500 line-clamp-1">
                                                <span style={`view-transition-name: event-time-${event.id}`}>
                                                    {timeStr}
                                                </span>
                                                {event.location && (
                                                    <>
                                                        {' · '}
                                                        <span
                                                            style={`view-transition-name: event-location-${event.id}`}
                                                        >
                                                            {event.location}
                                                        </span>
                                                    </>
                                                )}
                                            </p>
                                        </div>
                                    </a>
                                );
                            })}
                        </div>

                        {/* Pagination */}
                        {(hasPrevPage || hasNextPage) && (
                            <div class="mt-8 flex items-center justify-center gap-3">
                                {hasPrevPage && (
                                    <a
                                        href={buildPageUrl(page - 1)}
                                        class="press-sm group chip-tactile chip-inactive transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                                    >
                                        <span
                                            aria-hidden="true"
                                            class="inline-block transition-transform duration-200 group-hover:-translate-x-0.5 motion-reduce:transition-none"
                                        >
                                            ←
                                        </span>{' '}
                                        Previous
                                    </a>
                                )}
                                <span class="text-sm font-medium text-gray-500">
                                    Page {page} of {totalPages}
                                </span>
                                {hasNextPage && (
                                    <a
                                        href={buildPageUrl(page + 1)}
                                        class="press-sm arrow-nudge chip-tactile chip-inactive transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                                    >
                                        Next <span aria-hidden="true">→</span>
                                    </a>
                                )}
                            </div>
                        )}
                    </>
                )
            }
        </div>
    </main>

    <BottomTabDock active="events" />
</Layout>

<script>
    import type { EventDocument } from '../lib/typesense';

    // Same-origin call to /api/search keeps the Typesense search key off the
    // client and sidesteps any cross-origin CORS friction with the Typesense host.
    async function searchEventsApi(
        query: string,
        options: { per_page?: number; page?: number } = {},
    ): Promise<{ results: EventDocument[]; found: number; search_time_ms: number; error?: string }> {
        const params = new URLSearchParams({
            q: query,
            per_page: String(options.per_page ?? 20),
            page: String(options.page ?? 1),
        });
        try {
            const res = await fetch(`/api/search?${params.toString()}`, { credentials: 'omit' });
            if (!res.ok) return { results: [], found: 0, search_time_ms: 0, error: `HTTP ${res.status}` };
            return await res.json();
        } catch (err) {
            return {
                results: [],
                found: 0,
                search_time_ms: 0,
                error: err instanceof Error ? err.message : 'Search failed',
            };
        }
    }

    const input = document.getElementById('search-input') as HTMLInputElement | null;
    const form = document.getElementById('search-form') as HTMLFormElement | null;
    const clearBtn = document.getElementById('search-clear') as HTMLButtonElement | null;
    const searchIcon = document.getElementById('search-icon');
    const searchCard = document.getElementById('search-card');
    const loadingStatus = document.getElementById('search-loading');
    const resultsRoot = document.getElementById('search-results');

    if (input && resultsRoot) {
        let inFlight: symbol | null = null;
        let debounceTimer: ReturnType<typeof setTimeout> | null = null;

        // Tiny DOM-builder — every text slot goes through textContent, never innerHTML.
        type Attrs = Record<string, string>;
        function el(tag: string, attrs: Attrs = {}, ...children: (Node | string | null | undefined)[]): HTMLElement {
            const e = document.createElement(tag);
            for (const [k, v] of Object.entries(attrs)) e.setAttribute(k, v);
            for (const c of children) {
                if (c == null) continue;
                e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
            }
            return e;
        }

        const formatTime = (date: Date): string =>
            date.toLocaleString('en-PH', {
                weekday: 'short',
                month: 'short',
                day: 'numeric',
                hour: 'numeric',
                minute: '2-digit',
                hour12: true,
            });

        function buildRow(event: EventDocument, index: number): HTMLElement {
            const date = new Date(event.start_time * 1000);
            const day = String(date.getDate()).padStart(2, '0');
            const month = date.toLocaleString('default', { month: 'short' });
            const detailUrl = `/events/${event.slug || event.id}`;
            const delay = Math.min(index, 7) * 30;
            const loc = event.location ? ` · ${event.location}` : '';

            const dateChip = (variant: 'light' | 'purple') => {
                const isPurple = variant === 'purple';
                return el(
                    'div',
                    {
                        class: isPurple
                            ? 'date-chip date-chip-purple inline-block text-center'
                            : 'date-chip absolute left-4 top-4 text-center',
                    },
                    el(
                        'div',
                        {
                            class: `text-xl font-extrabold leading-none ${isPurple ? 'text-purple-900' : 'text-gray-900'}`,
                        },
                        day,
                    ),
                    el(
                        'div',
                        {
                            class: `mt-1 text-[10px] font-bold uppercase tracking-wider ${isPurple ? 'text-purple-700' : 'text-gray-500'}`,
                        },
                        month,
                    ),
                );
            };

            let coverNode: HTMLElement | null = null;
            if (event.cover_photo) {
                const img = el('img', {
                    src: event.cover_photo,
                    alt: event.name,
                    loading: 'lazy',
                    class: 'cover-zoom h-full w-full object-cover',
                });
                coverNode = el('div', { class: 'relative aspect-[16/9] overflow-hidden' }, img, dateChip('light'));
            }

            const dateOnly = !event.cover_photo
                ? el('div', { class: 'mb-3 flex items-start' }, dateChip('purple'))
                : null;

            const body = el(
                'div',
                { class: 'p-5' },
                dateOnly,
                el(
                    'h3',
                    { class: 'mb-1.5 text-lg font-extrabold leading-snug text-gray-900 line-clamp-2' },
                    event.name,
                ),
                el('p', { class: 'text-sm text-gray-500 line-clamp-1' }, formatTime(date) + loc),
            );

            const card = el(
                'a',
                {
                    href: detailUrl,
                    class: 'press lift-hover card-tactile block overflow-hidden fade-up',
                    style: `animation-delay:${delay}ms`,
                    'data-astro-prefetch': 'viewport',
                },
                coverNode,
                body,
            );
            return card;
        }

        function buildStatusCard(title: string, body: string, ctaHref?: string, ctaLabel?: string): HTMLElement {
            const card = el(
                'div',
                { class: 'card-tactile p-8 text-center' },
                el('div', { class: 'mb-2 text-base font-extrabold text-gray-900' }, title),
                el('p', { class: 'text-sm text-gray-500' }, body),
            );
            if (ctaHref && ctaLabel) {
                card.appendChild(
                    el('a', { href: ctaHref, class: 'press-sm btn-primary-tactile mt-5 inline-flex' }, ctaLabel),
                );
            }
            return el('section', {}, card);
        }

        function renderEmpty() {
            const SUGGESTIONS = ['AI', 'hackathon', 'JavaScript', 'startup', 'design'];

            // Magnifying glass icon (matches the SSR'd empty state)
            const icon = (() => {
                const ns = 'http://www.w3.org/2000/svg';
                const svg = document.createElementNS(ns, 'svg');
                svg.setAttribute('width', '22');
                svg.setAttribute('height', '22');
                svg.setAttribute('viewBox', '0 0 22 22');
                svg.setAttribute('fill', 'none');
                svg.setAttribute('stroke', 'currentColor');
                svg.setAttribute('stroke-width', '1.75');
                svg.setAttribute('stroke-linecap', 'round');
                svg.setAttribute('stroke-linejoin', 'round');
                svg.setAttribute('aria-hidden', 'true');
                const circle = document.createElementNS(ns, 'circle');
                circle.setAttribute('cx', '10');
                circle.setAttribute('cy', '10');
                circle.setAttribute('r', '6');
                const line = document.createElementNS(ns, 'path');
                line.setAttribute('d', 'M19 19l-4-4');
                svg.appendChild(circle);
                svg.appendChild(line);
                return svg;
            })();

            const iconTile = el('div', {
                class: 'mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-purple-50 text-purple-600',
            });
            iconTile.appendChild(icon);

            const chipRow = el('div', { class: 'mt-5 flex flex-wrap justify-center gap-2' });
            for (const term of SUGGESTIONS) {
                chipRow.appendChild(
                    el(
                        'button',
                        {
                            type: 'button',
                            class: 'press-sm chip-tactile chip-inactive search-suggestion !text-xs transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0',
                            'data-suggestion': term,
                        },
                        term,
                    ),
                );
            }

            const card = el(
                'div',
                { class: 'card-tactile p-8 text-center' },
                iconTile,
                el('div', { class: 'mb-2 text-base font-extrabold text-gray-900' }, 'Find an event'),
                el('p', { class: 'text-sm text-gray-500' }, 'Try a keyword, organizer, or topic.'),
                chipRow,
            );
            resultsRoot!.replaceChildren(el('section', {}, card));
        }

        function renderNoResults(query: string) {
            const section = buildStatusCard(
                `No events match "${query}"`,
                'Try a broader keyword, or browse all upcoming events.',
                '/events',
                'Browse events',
            );
            const feedbackBtn = el(
                'button',
                {
                    type: 'button',
                    'data-open-feedback': '',
                    class: 'font-semibold text-gray-700 underline-offset-4 transition-colors hover:text-purple-700 hover:underline',
                },
                'Tell us',
            );
            section.appendChild(
                el(
                    'p',
                    {
                        class: 'mt-6 text-center text-sm text-gray-500',
                    },
                    "Looking for something we don't have? ",
                    feedbackBtn,
                ),
            );
            resultsRoot!.replaceChildren(section);
        }

        function renderError(message: string) {
            resultsRoot!.replaceChildren(
                buildStatusCard('Search is taking a break', `${message}. Try again in a bit.`),
            );
        }

        function renderResults(query: string, found: number, ms: number, results: EventDocument[]) {
            const header = el(
                'div',
                { class: 'mb-4 flex items-baseline justify-between' },
                el(
                    'h1',
                    { class: 'text-xl font-bold text-gray-900' },
                    `${found} ${found === 1 ? 'result' : 'results'}`,
                    ms > 0 ? el('span', { class: 'ml-2 text-xs font-medium text-gray-400' }, `in ${ms}ms`) : null,
                ),
                el('span', { class: 'text-xs font-medium text-gray-500' }, `for "${query}"`),
            );
            const list = el('div', { class: 'space-y-5' }, ...results.map(buildRow));
            resultsRoot!.replaceChildren(header, list);
        }

        function syncUrl(query: string) {
            const url = new URL(location.href);
            const trimmed = query.trim();
            if (trimmed) url.searchParams.set('q', trimmed);
            else url.searchParams.delete('q');
            url.searchParams.delete('page');
            history.replaceState(null, '', url.toString());
        }

        function setSearchPending(on: boolean) {
            searchIcon?.classList.toggle('searching', on);
            searchCard?.classList.toggle('is-searching', on);
            loadingStatus?.classList.toggle('hidden', !on);
            resultsRoot?.setAttribute('aria-busy', on ? 'true' : 'false');
        }

        function setClearVisible(visible: boolean) {
            clearBtn?.classList.toggle('hidden', !visible);
        }

        async function performSearch(rawQuery: string) {
            const query = rawQuery.trim();
            syncUrl(query);
            setClearVisible(query.length > 0);

            if (!query) {
                inFlight = null;
                setSearchPending(false);
                renderEmpty();
                return;
            }

            const myReq = Symbol('searchReq');
            inFlight = myReq;
            setSearchPending(true);

            try {
                const res = await searchEventsApi(query, { per_page: 20, page: 1 });
                if (inFlight !== myReq) return;

                if (res.error) renderError(res.error);
                else if ((res.found ?? 0) === 0) renderNoResults(query);
                else renderResults(query, res.found ?? 0, res.search_time_ms ?? 0, res.results as EventDocument[]);
            } catch (err) {
                if (inFlight !== myReq) return;
                console.error('Instant search failed:', err);
                renderError('Search service unavailable');
            } finally {
                if (inFlight === myReq) setSearchPending(false);
            }
        }

        function debouncedSearch(query: string) {
            if (debounceTimer) clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => performSearch(query), 180);
        }

        input.addEventListener('input', () => debouncedSearch(input.value));

        form?.addEventListener('submit', (e) => {
            e.preventDefault();
            if (debounceTimer) clearTimeout(debounceTimer);
            performSearch(input.value);
        });

        clearBtn?.addEventListener('click', () => {
            input.value = '';
            input.focus();
            if (debounceTimer) clearTimeout(debounceTimer);
            performSearch('');
        });

        // Suggestion chips: tap to populate input + run the search.
        // Delegated on the results root since the empty state is replaced
        // wholesale on each render — direct binding wouldn't survive.
        resultsRoot.addEventListener('click', (e) => {
            const target = (e.target as HTMLElement)?.closest('.search-suggestion');
            if (!(target instanceof HTMLElement)) return;
            const term = target.getAttribute('data-suggestion');
            if (!term) return;
            input.value = term;
            input.focus();
            if (debounceTimer) clearTimeout(debounceTimer);
            performSearch(term);
        });
    }
</script>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    /* Suppress the browser-native clear (X) on type="search" — we render our own */
    input[type='search']::-webkit-search-cancel-button,
    input[type='search']::-webkit-search-decoration {
        appearance: none;
        -webkit-appearance: none;
    }
    /* Search card — soft purple glow when input is focused */
    .search-card {
