---
import AppHeader from '../components/AppHeader.astro';
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';
import type { AccountsFromDB } from '../types/database';
import SEO from '../components/SEO.astro';

const { data: partners, error } = (await supabase.from('accounts').select('*').order('name', { ascending: true })) as {
    data: AccountsFromDB[] | null;
    error: any;
};

if (error) console.error('Error fetching partners:', error);

// Count events per partner so the page reflects real activity, not just logos
const { data: eventCounts } = (await supabase
    .from('events')
    .select('account_id')
    .or('is_hidden.is.null,is_hidden.eq.false')
    .not('account_id', 'is', null)) as { data: { account_id: any }[] | null; error: any };

// Try to determine if account_id maps to partner.id or partner.account_id by sampling
const sampleAccountId = eventCounts?.[0]?.account_id;
const matchByPk = partners?.some((p) => String(p.id) === String(sampleAccountId)) ?? false;

// Build the count map using whichever key matches
const countByAccount = new Map<string, number>();
for (const e of eventCounts ?? []) {
    if (e?.account_id != null) {
        const key = String(e.account_id);
        countByAccount.set(key, (countByAccount.get(key) ?? 0) + 1);
    }
}

function eventsForPartner(p: AccountsFromDB): number {
    if (matchByPk) return countByAccount.get(String(p.id)) ?? 0;
    // Fallback: try matching against the FB account_id
    return countByAccount.get(String(p.account_id)) ?? 0;
}

const partnerCount = partners?.length ?? 0;
const totalTrackedEvents = (eventCounts ?? []).length;

const title = 'Partners — cebby';
const metaDescription = `${partnerCount} Cebu tech communities and organizations whose events Cebby aggregates. Trusted organizers auto-flow into the feed; their events power the directory.`;

const partnersJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: title,
    description: metaDescription,
    publisher: {
        '@type': 'Organization',
        name: 'Cebby',
        logo: { '@type': 'ImageObject', url: new URL('/icons/icon-512x512.png', Astro.url) },
    },
    mainEntity: {
        '@type': 'ItemList',
        itemListElement: partners?.slice(0, 10).map((p, i) => ({
            '@type': 'ListItem',
            position: i + 1,
            item: {
                '@type': 'Organization',
                name: p.name,
                image: p.primary_photo,
                url: `https://www.facebook.com/${p.account_id}`,
            },
        })),
    },
};
---

<Layout title={title} showFooter={true}>
    <Fragment slot="head">
        <SEO title={title} description={metaDescription} image="/screenshots/image4.png" type="website" />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(partnersJsonLd)} />
    </Fragment>

    <AppHeader showSearch={false} />

    <main class="mx-auto max-w-3xl px-5 pb-20 pt-2">
        {/* Header */}
        <header class="mb-8">
            <h1 class="text-2xl font-extrabold text-gray-900">Partners</h1>
            <p class="mt-1 max-w-2xl text-sm text-gray-500">
                Cebu tech communities and organizations whose events Cebby aggregates. These trusted organizers
                auto-flow into the feed — their events power the directory.
            </p>
        </header>

        {/* Stat strip */}
        {
            partners && (
                <section class="mb-8 grid gap-3 sm:grid-cols-2">
                    <div class="card-tactile p-5">
                        <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">Partners</div>
                        <div class="text-3xl font-extrabold leading-none text-gray-900">{partnerCount}</div>
                        <div class="mt-2 text-xs font-medium text-gray-500">Cebu tech communities</div>
                    </div>
                    <div class="card-tactile p-5">
                        <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">
                            Events tracked
                        </div>
                        <div class="text-3xl font-extrabold leading-none text-gray-900">{totalTrackedEvents}</div>
                        <div class="mt-2 text-xs font-medium text-gray-500">across all sources, all-time</div>
                    </div>
                </section>
            )
        }

        {/* Error state */}
        {
            error && (
                <div class="card-tactile p-8 text-center">
                    <div class="mb-2 text-base font-extrabold text-gray-900">Couldn't load partners</div>
                    <p class="mb-5 text-sm text-gray-500">Try refreshing the page in a moment.</p>
                    <button
                        onclick="window.location.reload()"
                        class="press-sm btn-primary-tactile"
                    >
                        Try again
                    </button>
                </div>
            )
        }

        {/* Partners grid */}
        {
            partners && partners.length > 0 && (
                <section>
                    <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 sm:gap-5">
                        {partners.map((partner) => {
                            const events = eventsForPartner(partner);
                            return (
                                <div class="press card-tactile flex flex-col overflow-hidden">
                                    {/* Logo — square, contain, soft padding */}
                                    <div class="logo-tile flex aspect-square items-center justify-center p-5">
                                        {partner.primary_photo ? (
                                            <img
                                                src={partner.primary_photo}
                                                alt={partner.name}
                                                width="240"
                                                height="240"
                                                loading="lazy"
                                                decoding="async"
                                                class="max-h-full max-w-full object-contain"
                                                onerror="this.onerror=null; this.style.display='none'; this.parentElement.querySelector('.logo-fallback')?.classList.remove('hidden');"
                                            />
                                        ) : null}
                                        <div
                                            class:list={[
                                                'logo-fallback flex h-full w-full items-center justify-center rounded-2xl bg-purple-50 text-3xl font-extrabold text-purple-600',
                                                partner.primary_photo && 'hidden',
                                            ]}
                                        >
                                            {partner.name.charAt(0).toUpperCase()}
                                        </div>
                                    </div>

                                    {/* Body */}
                                    <div class="flex flex-1 flex-col gap-3 px-4 pb-4">
                                        <h2 class="text-sm font-extrabold leading-tight text-gray-900 line-clamp-2">
                                            {partner.name}
                                        </h2>
                                        <div class="mt-auto flex items-center justify-between">
                                            <span class="pill-tactile pill-emerald !text-[11px]">
                                                {events} {events === 1 ? 'event' : 'events'}
                                            </span>
                                            <a
                                                href={`https://www.facebook.com/${partner.account_id}`}
                                                target="_blank"
                                                rel="noopener noreferrer"
                                                aria-label={`${partner.name} on Facebook`}
                                                class="press-sm flex h-8 w-8 items-center justify-center rounded-full bg-stone-50 text-gray-500 hover:text-purple-700"
                                            >
                                                <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor">
                                                    <path
                                                        fill-rule="evenodd"
                                                        d="M5.22 14.78a.75.75 0 001.06 0l7.22-7.22v5.69a.75.75 0 001.5 0v-7.5a.75.75 0 00-.75-.75h-7.5a.75.75 0 000 1.5h5.69l-7.22 7.22a.75.75 0 000 1.06z"
                                                        clip-rule="evenodd"
                                                    />
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            );
                        })}
                    </div>
                </section>
            )
        }

        {/* CTA — propose to join */}
        <section class="mt-12">
            <div class="card-tactile p-6 text-center">
                <h2 class="mb-2 text-base font-extrabold text-gray-900">
                    Run a Cebu tech community?
                </h2>
                <p class="mx-auto mb-5 max-w-md text-sm text-gray-500">
                    Cebby auto-aggregates events from Luma, Eventbrite, Meetup, and Facebook. If your community runs
                    events on those platforms, your events will appear here automatically — and your org can earn a
                    spot on this whitelist.
                </p>
                <a
                    href="https://github.com/getcebby/cebby/issues/new"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="press-sm btn-primary-tactile inline-flex"
                >
                    Suggest your community →
                </a>
            </div>
        </section>
    </main>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .logo-tile {
        background: linear-gradient(180deg, #ffffff 0%, #fafaf9 100%);
        border-bottom: 1px solid rgba(15, 15, 15, 0.04);
    }
</style>
