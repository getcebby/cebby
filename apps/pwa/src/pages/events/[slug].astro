---
export const prerender = false;

import Layout from '../../layouts/Layout.astro';
import BottomTabDock from '../../components/BottomTabDock.astro';
import { supabase } from '../../lib/supabase';
import SaveEventButton from '../../components/SaveEventButton.astro';
import RelatedEvents from '../../components/RelatedEvents.astro';
import EventMap from '../../components/EventMap.astro';
import RsvpButton from '../../components/RsvpButton.astro';
import RSVPModalSimple from '../../components/RSVPModalSimple.astro';
import SmartRSVPButton from '../../components/SmartRSVPButton.astro';
import SEO from '../../components/SEO.astro';
import { getEventTimeDisplay } from '../../utils/date';
import { Image } from 'astro:assets';

const { slug } = Astro.params;
const isNumericId = /^\d+$/.test(slug!);

let event;
let error;

if (isNumericId) {
    const result = await supabase.from('events').select('*,accounts!left(*)').eq('id', parseInt(slug!, 10)).single();
    event = result.data;
    error = result.error;
} else {
    const slugResult = await supabase
        .from('events')
        .select('*,event_slugs!inner(),accounts!left(*)')
        .eq('event_slugs.slug', slug!)
        .single();

    if (slugResult.error || !slugResult.data) {
        const eventId = slug?.split('--')[1];
        const idResult = await supabase
            .from('events')
            .select('*,accounts!left(*)')
            .eq('id', parseInt(eventId!, 10))
            .single();
        event = idResult.data;
        error = idResult.error;
    } else {
        event = slugResult.data;
        error = slugResult.error;
    }
}

if (error) console.error('Error fetching event:', error);
if (!event) return new Response(null, { status: 404 });
if (event?.slug && event?.slug !== slug) return Astro.redirect(`/events/${event.slug}`);

const organizer = event?.accounts;
const formattedDate = event.start_time ? getEventTimeDisplay(event.start_time, event.end_time || undefined) : '';
const ogImage = event?.cover_photo || '/og.png';

const now = new Date();
const startTime = new Date(event.start_time);
const endTime = event.end_time ? new Date(event.end_time) : null;
const hasStarted = now > startTime;
const hasEnded = endTime ? now > endTime : hasStarted && now > new Date(startTime.getTime() + 4 * 60 * 60 * 1000);
const deadlinePassed = event.registration_deadline && now > new Date(event.registration_deadline);
const registrationEnabled = event.registration_enabled;
const registrationClosed = registrationEnabled && (hasStarted || deadlinePassed);

const day = startTime.getDate().toString().padStart(2, '0');
const month = startTime.toLocaleString('default', { month: 'short' });
const weekday = startTime.toLocaleString('default', { weekday: 'long' });

const { data: relatedEvents } = await supabase
    .from('events')
    .select('*')
    .neq('id', event?.id)
    .is('is_hidden', false)
    .gte('start_time', new Date().toISOString())
    .limit(3)
    .order('start_time', { ascending: true });

let rsvpCount = 0;
if (registrationEnabled) {
    const { count } = await supabase
        .from('event_registrations')
        .select('*', { count: 'exact', head: true })
        .eq('event_id', event.id)
        .in('status', ['confirmed', 'pending', 'walkin']);
    if (count) rsvpCount = count;
}

const ctaHeadline = hasEnded
    ? 'Event has ended'
    : registrationClosed
      ? 'Registration closed'
      : registrationEnabled
        ? 'Registration is open'
        : 'Going to this event?';

let ctaSubline: string;
if (hasEnded) {
    ctaSubline = 'Catch the next one — subscribe to the calendar so you do not miss it.';
} else if (rsvpCount === 0) {
    ctaSubline = 'Be the first to register.';
} else if (rsvpCount <= 10) {
    ctaSubline = 'A few people are attending.';
} else {
    ctaSubline = `${rsvpCount} people are attending.`;
}

function linkifyText(text: string): string {
    const urlRegex = /(https?:\/\/[^\s]+)/g;
    return text.replace(urlRegex, (url) => {
        const cleanUrl = url.replace(/[.,;!?]$/, '');
        return `<a href="${cleanUrl}" target="_blank" rel="noopener noreferrer" class="text-purple-700 hover:text-purple-900 underline break-all">${cleanUrl}</a>`;
    });
}

const eventJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'Event',
    name: event.name,
    description: event.description,
    startDate: event.start_time,
    endDate: event.end_time || event.start_time,
    image: event.cover_photo ? new URL(event.cover_photo, Astro.url) : new URL('/og.png', Astro.url),
    location: {
        '@type': 'Place',
        name: event.location,
        address: { '@type': 'PostalAddress', addressLocality: event.location, addressRegion: 'Cebu', addressCountry: 'PH' },
    },
    organizer: { '@type': 'Organization', name: organizer?.name || 'cebby', url: Astro.url.origin },
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'PHP', availability: 'https://schema.org/InStock', url: Astro.url.href, validFrom: event.created_at },
    eventStatus: 'https://schema.org/ScheduledEvent',
    eventAttendanceMode: event.location?.toLowerCase()?.includes('online')
        ? 'https://schema.org/OnlineEventAttendanceMode'
        : 'https://schema.org/OfflineEventAttendanceMode',
    performer: { '@type': 'Organization', name: organizer?.name || 'Event Organizer' },
};
---

<Layout title={`${event.name} - cebby`}>
    <Fragment slot="head">
        <SEO title={`${event.name} - cebby`} description={event?.description || 'Cebu tech events'} image={ogImage} />
        <script is:inline type="application/ld+json" set:html={JSON.stringify(eventJsonLd)} />
    </Fragment>

    <main class="mx-auto max-w-2xl px-5 pb-32 pt-safe">
        {/* Top bar — back button + share/save */}
        <header class="flex items-center justify-between pt-6 pb-5">
            <a
                href="/events"
                class="press-sm shadow-soft-1 flex h-10 w-10 items-center justify-center rounded-full bg-white text-gray-700"
                aria-label="Back to events"
            >
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <path d="M11 4l-5 5 5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
            </a>
            <div class="flex items-center gap-2">
                <button
                    id="shareButton"
                    class="press-sm shadow-soft-1 flex h-10 items-center gap-2 rounded-full bg-white px-4 text-sm font-semibold text-gray-700"
                    aria-label="Share event"
                >
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="18" cy="5" r="3" />
                        <circle cx="6" cy="12" r="3" />
                        <circle cx="18" cy="19" r="3" />
                        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
                        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
                    </svg>
                    Share
                </button>
                <SaveEventButton event={event} />
            </div>
        </header>

        {/* Cover photo */}
        {
            event.cover_photo && (
                <div class="card-tactile mb-6 overflow-hidden">
                    <button
                        type="button"
                        id="expandImageBtn"
                        class="press block w-full"
                        aria-label="View full image"
                    >
                        <Image
                            src={event.cover_photo}
                            alt={event.name}
                            width={1200}
                            height={675}
                            loading="eager"
                            class="h-auto w-full"
                        />
                    </button>
                </div>
            )
        }

        {/* Title + meta card */}
        <section class="card-tactile mb-6 p-6">
            <div class="mb-4 flex items-start gap-4">
                <div class={`date-chip ${event.cover_photo ? '' : 'date-chip-purple'} flex-shrink-0 text-center`}>
                    <div class={`text-xl font-extrabold leading-none ${event.cover_photo ? 'text-gray-900' : 'text-purple-900'}`}>
                        {day}
                    </div>
                    <div class={`mt-1 text-[10px] font-bold uppercase tracking-wider ${event.cover_photo ? 'text-gray-500' : 'text-purple-700'}`}>
                        {month}
                    </div>
                </div>
                <div class="min-w-0 flex-1">
                    <h1 class="mb-1 text-xl font-extrabold leading-snug text-gray-900" data-organization={organizer?.name}>
                        {event.name}
                    </h1>
                    {organizer?.name && <p class="text-sm font-medium text-gray-500">by {organizer.name}</p>}
                </div>
            </div>

            <div class="space-y-2 text-sm text-gray-700">
                <div class="flex items-center gap-2">
                    <svg class="h-4 w-4 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <time datetime={event.start_time}>{formattedDate}</time>
                    {event.end_time && <time class="hidden" datetime={event.end_time} data-end-time></time>}
                </div>
                {event.location && (
                    <div class="flex items-start gap-2">
                        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span data-location>{event.location}</span>
                    </div>
                )}
            </div>
        </section>

        {/* Primary CTA — registration */}
        <section class="card-tactile mb-6 p-5">
            <div class="mb-1 text-base font-extrabold text-gray-900">{ctaHeadline}</div>
            <p class="mb-4 text-sm text-gray-500">{ctaSubline}</p>
            <div class="flex flex-wrap items-center gap-3">
                {
                    !hasEnded && registrationEnabled ? (
                        <>
                            <SmartRSVPButton
                                eventId={event.id?.toString()}
                                eventName={event?.name || ''}
                                registrationLimit={event.registration_limit}
                                registrationDeadline={event.registration_deadline}
                                eventStartTime={event.start_time}
                            />
                            <RSVPModalSimple eventId={event.id?.toString()} eventName={event?.name || ''} isManagedEvent={true} />
                        </>
                    ) : !hasEnded ? (
                        <RsvpButton event={event} />
                    ) : (
                        <a href="/calendar" class="press-sm btn-primary-tactile">
                            Subscribe to calendar →
                        </a>
                    )
                }
                <button id="addToCalendarButton" class="press-sm shadow-soft-1 flex h-10 items-center gap-2 rounded-full bg-white px-4 text-sm font-semibold text-gray-700">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
                        <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                    Add to calendar
                </button>
            </div>
        </section>

        {/* Map */}
        {
            event.location && (
                <section class="mb-6">
                    <h2 class="mb-3 text-lg font-bold text-gray-900">Location</h2>
                    <div class="card-tactile overflow-hidden">
                        <EventMap location={event.location} name={event.name || ''} />
                    </div>
                </section>
            )
        }

        {/* Description */}
        {
            event.description && (
                <section class="mb-6">
                    <h2 class="mb-3 text-lg font-bold text-gray-900">About</h2>
                    <div class="card-tactile p-6">
                        <p
                            class="whitespace-pre-wrap text-sm leading-relaxed text-gray-700"
                            set:html={linkifyText(event.description)}
                        />
                    </div>
                </section>
            )
        }

        {/* Related events */}
        {
            relatedEvents && relatedEvents.length > 0 && (
                <section class="mb-6">
                    <h2 class="mb-3 text-lg font-bold text-gray-900">Similar events</h2>
                    <RelatedEvents events={relatedEvents} />
                </section>
            )
        }
    </main>

    {/* Lightbox */}
    {
        event.cover_photo && (
            <div id="imageModal" class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/90">
                <button type="button" id="closeModalBtn" class="press-sm absolute right-5 top-5 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white" aria-label="Close">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
                <Image src={event.cover_photo} alt={event.name} width={1920} height={1080} class="max-h-[90vh] max-w-[95%] object-contain" />
            </div>
        )
    }

    {/* Share menu */}
    <div id="shareMenu" class="fixed bottom-24 right-5 z-50 hidden">
        <div class="card-tactile w-56 overflow-hidden p-1">
            <button id="copyLinkButton" class="press-sm flex w-full items-center gap-3 rounded-xl px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-gray-50">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                </svg>
                <span data-label>Copy link</span>
            </button>
            <button id="nativeShareButton" class="press-sm flex w-full items-center gap-3 rounded-xl px-4 py-3 text-left text-sm font-medium text-gray-700 hover:bg-gray-50">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <circle cx="18" cy="5" r="3" />
                    <circle cx="6" cy="12" r="3" />
                    <circle cx="18" cy="19" r="3" />
                    <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
                    <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
                </svg>
                <span>More options</span>
            </button>
        </div>
    </div>

    <BottomTabDock active="events" />
</Layout>

<script>
    if (typeof window !== 'undefined' && (window as any).umami) {
        (window as any).umami.track('event_view', {
            event_id: window.location.pathname.split('/').pop(),
            event_name: document.title,
            organization: document.querySelector('[data-organization]')?.getAttribute('data-organization'),
        });
    }

    // Lightbox
    const expandBtn = document.getElementById('expandImageBtn');
    const modal = document.getElementById('imageModal');
    const closeBtn = document.getElementById('closeModalBtn');
    if (expandBtn && modal && closeBtn) {
        expandBtn.addEventListener('click', () => {
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        });
        closeBtn.addEventListener('click', () => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = '';
        });
        modal.addEventListener('click', (e) => {
            if (e.target === modal) {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
                document.body.style.overflow = '';
            }
        });
    }

    // Share menu
    const shareBtn = document.getElementById('shareButton');
    const shareMenu = document.getElementById('shareMenu');
    const copyLinkBtn = document.getElementById('copyLinkButton');
    const nativeShareBtn = document.getElementById('nativeShareButton');

    if (shareBtn && shareMenu) {
        shareBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            shareMenu.classList.toggle('hidden');
        });
        document.addEventListener('click', (e) => {
            if (!shareMenu.contains(e.target as Node) && e.target !== shareBtn) {
                shareMenu.classList.add('hidden');
            }
        });
    }

    if (copyLinkBtn) {
        copyLinkBtn.addEventListener('click', async () => {
            const labelEl = copyLinkBtn.querySelector('[data-label]') as HTMLElement | null;
            try {
                await navigator.clipboard.writeText(window.location.href);
                if (labelEl) {
                    labelEl.textContent = 'Copied!';
                    setTimeout(() => {
                        labelEl.textContent = 'Copy link';
                    }, 1500);
                }
            } catch (err) {
                console.error('Failed to copy:', err);
            }
        });
    }

    if (nativeShareBtn) {
        nativeShareBtn.addEventListener('click', async () => {
            if (navigator.share) {
                try {
                    await navigator.share({ title: document.title, url: window.location.href });
                } catch (err) {
                    if ((err as Error).name !== 'AbortError') console.error(err);
                }
            }
            shareMenu?.classList.add('hidden');
        });
    }

    // Add to calendar
    const addToCalendarBtn = document.getElementById('addToCalendarButton');
    if (addToCalendarBtn) {
        addToCalendarBtn.addEventListener('click', () => {
            const startTimeEl = document.querySelector('time[datetime]') as HTMLTimeElement | null;
            const endTimeEl = document.querySelector('[data-end-time]') as HTMLTimeElement | null;
            const locationEl = document.querySelector('[data-location]') as HTMLElement | null;

            const title = document.title.replace(' - cebby', '');
            const start = startTimeEl?.dateTime || '';
            const end = endTimeEl?.dateTime || start;
            const location = locationEl?.textContent?.trim() || '';

            const formatDate = (iso: string) => iso.replace(/[-:]/g, '').replace(/\.\d+/, '');
            const url = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(title)}&dates=${formatDate(start)}/${formatDate(end)}&details=${encodeURIComponent(window.location.href)}&location=${encodeURIComponent(location)}`;
            window.open(url, '_blank');
        });
    }
</script>
