---
import type { Event } from '@service/core/supabase/shared/types.ts';
import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
import BottomTabDock from '../components/BottomTabDock.astro';
import SEO from '../components/SEO.astro';
import { supabase } from '../lib/supabase';
import {
    format,
    startOfMonth,
    endOfMonth,
    eachDayOfInterval,
    isToday as isDateToday,
    addMonths,
    subMonths,
} from 'date-fns';
import { formatInTimeZone } from 'date-fns-tz';

const urlParams = Astro.url.searchParams;
const dateParam = urlParams.get('date');
let selectedDate: Date;
try {
    selectedDate = dateParam ? new Date(dateParam) : new Date();
    if (isNaN(selectedDate.getTime())) selectedDate = new Date();
} catch {
    selectedDate = new Date();
}

const firstDayOfMonth = startOfMonth(selectedDate);
const lastDayOfMonth = endOfMonth(selectedDate);
const startDate = format(firstDayOfMonth, 'yyyy-MM-dd');
const endDate = format(lastDayOfMonth, 'yyyy-MM-dd');

const { data: events = [] } = await supabase
    .from('events')
    .select('id, slug, name, start_time, location, is_hidden')
    .filter('is_hidden', 'not.is', 'true')
    .gte('start_time', `${startDate}T00:00:00+00:00`)
    .lte('start_time', `${endDate}T23:59:59+00:00`)
    .order('start_time', { ascending: true });

// Edge-cache the rendered HTML for 60s, serve stale up to 5min while revalidating.
// Calendar-by-month is identical across users; per-user state is client-side only.
Astro.response.headers.set(
    'Cache-Control',
    'public, max-age=0, s-maxage=60, stale-while-revalidate=300',
);

// Dedupe by lowercase name
const uniqueEvents = (events ?? []).reduce((unique: Event[], event) => {
    if (!unique.find((e) => e?.name?.toLowerCase() === event.name?.toLowerCase())) unique.push(event);
    return unique;
}, []);

const eventsByDate = uniqueEvents.reduce((acc: Record<string, Event[]>, event) => {
    if (event.start_time) {
        const eventDate = formatInTimeZone(new Date(event.start_time), 'Asia/Manila', 'yyyy-MM-dd');
        if (!acc[eventDate]) acc[eventDate] = [];
        acc[eventDate].push(event);
    }
    return acc;
}, {});

function generateCalendarDays(month: number, year: number) {
    const firstDay = new Date(year, month, 1);
    const lastDay = new Date(year, month + 1, 0);
    const days = eachDayOfInterval({ start: firstDay, end: lastDay });
    const startPadding = firstDay.getDay();
    return [...Array(startPadding).fill(null), ...days];
}

const calendarDays = generateCalendarDays(selectedDate.getMonth(), selectedDate.getFullYear());
const monthName = format(selectedDate, 'MMMM yyyy');
const prevMonth = format(subMonths(selectedDate, 1), 'yyyy-MM-dd');
const nextMonth = format(addMonths(selectedDate, 1), 'yyyy-MM-dd');

const metaDescription = 'View all tech events in Cebu in a calendar format. Subscribe once and never miss an event.';

// Subscribe URLs (from SubscribeToCalendar.astro)
const calendarURL = 'https://www.getcebby.com/api/calendar';
const stripProtocol = (u: string) => u.replace(/^https?:\/\//, '');
const httpify = (u: string) => u.replace(/^https?:\/\//, 'http://');
const subscribeUrls = {
    google: `https://calendar.google.com/calendar/render?cid=${encodeURIComponent(httpify(calendarURL))}`,
    apple: `webcal://${encodeURIComponent(stripProtocol(calendarURL))}`,
    outlook: `https://outlook.live.com/calendar/0/addcalendar?url=${encodeURIComponent('webcal://' + stripProtocol(calendarURL))}`,
    download: calendarURL,
};

const dayLabels = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
---

<Layout title="Calendar — cebby">
    <Fragment slot="head">
        <SEO title="Calendar — cebby" description={metaDescription} image="/og.png" type="website" />
    </Fragment>

    <AppHeader showSearch={false} />

    <main class="mx-auto max-w-2xl px-5 pb-32 pt-2">
        {/* Subscribe nudge — the headline value of this page. Purple-tinted
           surface so it visually wins over the calendar grid below. Copy
           lifted from .impeccable.md's "Calendar subscribe nudge" anchor. */}
        <section class="mb-6">
            <div class="subscribe-card p-6" style="view-transition-name: subscribe-card-surface">
                <div class="mb-5 flex items-start gap-4">
                    <div
                        class="date-chip subscribe-icon flex h-12 w-12 flex-shrink-0 items-center justify-center"
                        style="padding: 0; view-transition-name: subscribe-card-icon"
                    >
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="text-purple-700">
                            <path
                                d="M3 8h16M5 4h12a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2zM7 2v4M15 2v4"
                                stroke="currentColor"
                                stroke-width="1.75"
                                stroke-linecap="round"></path>
                        </svg>
                    </div>
                    <div class="min-w-0 flex-1">
                        <h1
                            class="text-lg font-extrabold text-gray-900 sm:text-xl"
                            style="view-transition-name: subscribe-card-headline"
                        >
                            Never miss a Cebu tech event
                        </h1>
                        <p
                            class="mt-1 text-sm text-gray-600"
                            style="view-transition-name: subscribe-card-subline"
                        >
                            Subscribe once — all events appear in your calendar. No app to open.
                        </p>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-2.5 sm:grid-cols-4">
                    <a
                        href={subscribeUrls.google}
                        target="_blank"
                        rel="noopener"
                        class="press-sm chip-tactile chip-inactive subscribe-chip !inline-flex items-center justify-center gap-2 !text-sm transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                        style="animation-delay: 80ms"
                    >
                        {/* Google "G" — 4-color brand mark, recognizable at 14px */}
                        <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
                            <path
                                fill="#4285F4"
                                d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                            ></path>
                            <path
                                fill="#34A853"
                                d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                            ></path>
                            <path
                                fill="#FBBC05"
                                d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                            ></path>
                            <path
                                fill="#EA4335"
                                d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                            ></path>
                        </svg>
                        Google
                    </a>
                    <a
                        href={subscribeUrls.apple}
                        class="press-sm chip-tactile chip-inactive subscribe-chip !inline-flex items-center justify-center gap-2 !text-sm transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                        style="animation-delay: 140ms"
                    >
                        {/* Apple — uses currentColor so it picks up hover tint */}
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                            <path
                                d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"
                            ></path>
                        </svg>
                        Apple
                    </a>
                    <a
                        href={subscribeUrls.outlook}
                        target="_blank"
                        rel="noopener"
                        class="press-sm chip-tactile chip-inactive subscribe-chip !inline-flex items-center justify-center gap-2 !text-sm transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                        style="animation-delay: 200ms"
                    >
                        {/* Outlook — Microsoft brand blue */}
                        <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill="#0078D4" d="M14 4h7a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-7zM2 6.5l10-1.5v14L2 17.5z"
                            ></path>
                            <circle cx="7" cy="12" r="2.6" fill="#fff"></circle>
                        </svg>
                        Outlook
                    </a>
                    <a
                        href={subscribeUrls.download}
                        download="cebby.ics"
                        class="press-sm chip-tactile chip-inactive subscribe-chip !inline-flex items-center justify-center gap-2 !text-sm transition-all duration-200 hover:-translate-y-0.5 hover:text-purple-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0"
                        style="animation-delay: 260ms"
                    >
                        {/* Download — generic action, monochrome currentColor */}
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                        >
                            <path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14"></path>
                        </svg>
                        Download
                    </a>
                </div>
            </div>
        </section>

        {/* Month navigation */}
        <section class="cal-section-in mb-4" style="animation-delay: 200ms">
            <div class="flex items-center justify-between">
                <a
                    href={`/calendar?date=${prevMonth}`}
                    class="press-sm group shadow-soft-1 flex h-10 w-10 items-center justify-center rounded-full bg-white text-gray-700 transition-colors duration-200 hover:text-purple-700"
                    aria-label="Previous month"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 18 18"
                        fill="none"
                        class="transition-transform duration-200 group-hover:-translate-x-0.5 motion-reduce:transition-none motion-reduce:group-hover:translate-x-0"
                    >
                        <path
                            d="M11 4l-5 5 5 5"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </a>
                <h2 class="text-lg font-bold text-gray-900">{monthName}</h2>
                <a
                    href={`/calendar?date=${nextMonth}`}
                    class="press-sm group shadow-soft-1 flex h-10 w-10 items-center justify-center rounded-full bg-white text-gray-700 transition-colors duration-200 hover:text-purple-700"
                    aria-label="Next month"
                >
                    <svg
                        width="18"
                        height="18"
                        viewBox="0 0 18 18"
                        fill="none"
                        class="transition-transform duration-200 group-hover:translate-x-0.5 motion-reduce:transition-none motion-reduce:group-hover:translate-x-0"
                    >
                        <path
                            d="M7 4l5 5-5 5"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </a>
            </div>
        </section>

        {/* Calendar grid */}
        <section class="cal-section-in mb-8" style="animation-delay: 280ms">
            <div class="card-tactile p-4">
                <div class="mb-2 grid grid-cols-7 gap-1 text-center">
                    {
                        dayLabels.map((label) => (
                            <div class="text-[10px] font-bold uppercase tracking-wider text-gray-400">{label}</div>
                        ))
                    }
                </div>
                <div class="grid grid-cols-7 gap-1">
                    {
                        calendarDays.map((day) => {
                            if (!day) return <div />;
                            const dateStr = format(day, 'yyyy-MM-dd');
                            const dayEvents = eventsByDate[dateStr] || [];
                            const isToday = isDateToday(day);
                            const hasEvents = dayEvents.length > 0;
                            return (
                                <a
                                    href={`#day-${dateStr}`}
                                    class:list={[
                                        'press-sm flex aspect-square flex-col items-center justify-center rounded-xl text-sm transition-all duration-150 hover:bg-purple-50 hover:text-purple-700 motion-reduce:transition-none',
                                        isToday && 'bg-purple-100 font-bold text-purple-900 hover:!bg-purple-200',
                                        !isToday && hasEvents && 'font-bold text-gray-900',
                                        !isToday && !hasEvents && 'text-gray-500',
                                    ]}
                                >
                                    <span>{format(day, 'd')}</span>
                                    {hasEvents && (
                                        <span
                                            class:list={[
                                                'mt-0.5 h-1 w-1 rounded-full',
                                                isToday ? 'bg-purple-700' : 'bg-purple-500',
                                            ]}
                                        />
                                    )}
                                </a>
                            );
                        })
                    }
                </div>
            </div>
        </section>

        {/* Events grouped by date */}
        {
            Object.keys(eventsByDate).length > 0 ? (
                <section class="space-y-6">
                    <h2 class="cal-section-in text-xl font-bold text-gray-900" style="animation-delay: 400ms">
                        Events this month
                    </h2>
                    {Object.entries(eventsByDate)
                        .sort(([a], [b]) => a.localeCompare(b))
                        .map(([dateStr, dayEvents], index) => {
                            const dayDate = new Date(dateStr);
                            return (
                                <div
                                    id={`day-${dateStr}`}
                                    class="cal-section-in space-y-3"
                                    style={`animation-delay: ${460 + index * 70}ms`}
                                >
                                    <h3 class="flex items-center gap-2 text-sm font-bold text-gray-700">
                                        <span class="rounded-full bg-purple-100 px-2.5 py-1 text-xs font-bold text-purple-700">
                                            {format(dayDate, 'EEE, MMM d')}
                                        </span>
                                    </h3>
                                    <div class="space-y-3">
                                        {dayEvents.map((event) => (
                                            <a
                                                href={`/events/${event.slug || event.id}`}
                                                class="press lift-hover card-tactile flex items-center gap-4 p-4"
                                                data-astro-prefetch="viewport"
                                            >
                                                <div
                                                    class="date-chip date-chip-purple flex-shrink-0 text-center"
                                                    style={`view-transition-name: event-date-${event.id}`}
                                                >
                                                    <div class="text-base font-extrabold leading-none text-purple-900">
                                                        {format(new Date(event.start_time!), 'd').padStart(2, '0')}
                                                    </div>
                                                    <div class="mt-1 text-[9px] font-bold uppercase tracking-wider text-purple-700">
                                                        {format(new Date(event.start_time!), 'MMM')}
                                                    </div>
                                                </div>
                                                <div class="min-w-0 flex-1">
                                                    <div
                                                        class="line-clamp-1 text-sm font-extrabold text-gray-900"
                                                        style={`view-transition-name: event-title-${event.id}`}
                                                    >
                                                        {event.name}
                                                    </div>
                                                    <div class="mt-0.5 line-clamp-1 text-xs text-gray-500">
                                                        <span style={`view-transition-name: event-time-${event.id}`}>
                                                            {format(new Date(event.start_time!), 'h:mm a')}
                                                        </span>
                                                        {event.location && (
                                                            <>
                                                                {' · '}
                                                                <span style={`view-transition-name: event-location-${event.id}`}>
                                                                    {event.location}
                                                                </span>
                                                            </>
                                                        )}
                                                    </div>
                                                </div>
                                            </a>
                                        ))}
                                    </div>
                                </div>
                            );
                        })}
                </section>
            ) : (
                <section>
                    <div class="card-tactile p-8 text-center">
                        <div class="mb-2 text-base font-extrabold text-gray-900">No events this month</div>
                        <p class="text-sm text-gray-500">
                            Try a different month, or subscribe above so events appear automatically.
                        </p>
                    </div>
                </section>
            )
        }
    </main>

    <BottomTabDock active="calendar" />
</Layout>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Subscribe card — purple-tinted soft-3D variant of card-tactile.
       Used only here, where the subscribe action IS the page's job. */
    .subscribe-card {
        background: linear-gradient(180deg, #faf5ff 0%, #f3e8ff 100%);
        border-radius: 24px;
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.95),
            inset 0 0 0 1px rgba(147, 51, 234, 0.12),
            0 1px 2px rgba(147, 51, 234, 0.1),
            0 8px 20px rgba(147, 51, 234, 0.1),
            0 20px 40px rgba(147, 51, 234, 0.08);
    }

    /* Subscribe section entrance — runs once when /calendar loads.
       User-triggered (the tap that brought them here), so it respects
       principle #5 (tactility ON, ambient motion OFF). */
    @keyframes icon-pop-in {
        0% {
            transform: scale(0.6) rotate(-8deg);
            opacity: 0;
        }
        60% {
            transform: scale(1.08) rotate(2deg);
            opacity: 1;
        }
        100% {
            transform: scale(1) rotate(0);
            opacity: 1;
        }
    }
    @keyframes chip-rise {
        0% {
            transform: translateY(8px);
            opacity: 0;
        }
        100% {
            transform: translateY(0);
            opacity: 1;
        }
    }
    .subscribe-icon {
        animation: icon-pop-in 480ms cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
    }
    .subscribe-chip {
        animation: chip-rise 320ms cubic-bezier(0.2, 0, 0, 1) backwards;
    }

    /* Day groups in "Events this month" cascade in after the subscribe card
       settles. Same shape as the detail page's body section stagger. */
    @keyframes cal-section-in {
        0%   { transform: translateY(10px); opacity: 0; }
        100% { transform: translateY(0); opacity: 1; }
    }
    .cal-section-in {
        animation: cal-section-in 360ms cubic-bezier(0.2, 0, 0, 1) backwards;
    }

    @media (prefers-reduced-motion: reduce) {
        .subscribe-icon,
        .subscribe-chip,
        .cal-section-in {
            animation: none;
        }
    }
</style>
