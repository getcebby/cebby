---
import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
import BottomTabDock from '../components/BottomTabDock.astro';
---

<Layout title="Saved events — cebby">
    <AppHeader showSearch={false} />

    <main class="mx-auto max-w-2xl px-5 pb-32 pt-2">
        <header class="mb-6">
            <h1 class="text-xl font-bold text-gray-900">Saved events</h1>
            <p class="mt-1 text-sm text-gray-500">Events you've bookmarked.</p>
        </header>

        <div id="savedEventsContainer" class="space-y-5"></div>

        <div id="noSavedEvents" class="hidden">
            <div class="card-tactile p-8 text-center">
                <div class="mb-3 text-base font-extrabold text-gray-900">Nothing saved yet</div>
                <p class="text-sm text-gray-500">
                    Tap the bookmark icon on any event to keep track of it here.
                </p>
                <a href="/events" class="press-sm btn-primary-tactile mt-5 inline-flex">
                    Browse events
                </a>
            </div>
        </div>
    </main>

    <BottomTabDock active="saved" />
</Layout>

<script>
    import { resolveVenue } from '../data/venues';

    type SavedEvent = {
        id?: number;
        slug?: string | null;
        name?: string;
        start_time?: string;
        end_time?: string | null;
        location?: string | null;
        cover_photo?: string | null;
    };

    function pad2(n: number): string {
        return n.toString().padStart(2, '0');
    }

    function formatTimeRange(start: string, end?: string | null): string {
        try {
            const s = new Date(start);
            const startStr = s.toLocaleString('en-PH', {
                weekday: 'short',
                hour: 'numeric',
                minute: '2-digit',
                hour12: true,
            });
            if (end) {
                const e = new Date(end);
                const endStr = e.toLocaleString('en-PH', {
                    hour: 'numeric',
                    minute: '2-digit',
                    hour12: true,
                });
                return `${startStr} – ${endStr}`;
            }
            return startStr;
        } catch {
            return start;
        }
    }

    function buildEventCard(event: SavedEvent): HTMLAnchorElement {
        const a = document.createElement('a');
        a.href = `/events/${event.slug || event.id}`;
        a.className = 'press lift-hover card-tactile block overflow-hidden';
        a.setAttribute('data-astro-prefetch', 'viewport');

        const startDate = event.start_time ? new Date(event.start_time) : new Date();
        const day = pad2(startDate.getDate());
        const month = startDate.toLocaleString('default', { month: 'short' });

        if (event.cover_photo) {
            const photoWrap = document.createElement('div');
            photoWrap.className = 'relative aspect-[16/9] overflow-hidden';

            const img = document.createElement('img');
            img.src = event.cover_photo;
            img.alt = event.name || '';
            img.loading = 'lazy';
            img.className = 'cover-zoom h-full w-full object-cover';
            photoWrap.appendChild(img);

            const chip = document.createElement('div');
            chip.className = 'date-chip absolute left-4 top-4 text-center';
            const dayEl = document.createElement('div');
            dayEl.className = 'text-xl font-extrabold leading-none text-gray-900';
            dayEl.textContent = day;
            const monthEl = document.createElement('div');
            monthEl.className = 'mt-1 text-[10px] font-bold uppercase tracking-wider text-gray-500';
            monthEl.textContent = month;
            chip.appendChild(dayEl);
            chip.appendChild(monthEl);
            photoWrap.appendChild(chip);

            a.appendChild(photoWrap);
        }

        const body = document.createElement('div');
        body.className = 'p-5';

        if (!event.cover_photo) {
            const head = document.createElement('div');
            head.className = 'mb-3 flex items-start justify-between';
            const chip = document.createElement('div');
            chip.className = 'date-chip date-chip-purple inline-block text-center';
            const dayEl = document.createElement('div');
            dayEl.className = 'text-xl font-extrabold leading-none text-purple-900';
            dayEl.textContent = day;
            const monthEl = document.createElement('div');
            monthEl.className = 'mt-1 text-[10px] font-bold uppercase tracking-wider text-purple-700';
            monthEl.textContent = month;
            chip.appendChild(dayEl);
            chip.appendChild(monthEl);
            head.appendChild(chip);
            body.appendChild(head);
        }

        const title = document.createElement('h3');
        title.className = 'mb-1.5 text-lg font-extrabold leading-snug text-gray-900 line-clamp-2';
        title.textContent = event.name || '';
        body.appendChild(title);

        const meta = document.createElement('p');
        meta.className = 'text-sm text-gray-500 line-clamp-1';
        meta.textContent = event.start_time ? formatTimeRange(event.start_time, event.end_time) : '';
        body.appendChild(meta);

        if (event.location) {
            body.appendChild(buildVenueChip(event.location));
        }

        a.appendChild(body);
        return a;
    }

    function buildPinIcon(): SVGSVGElement {
        const ns = 'http://www.w3.org/2000/svg';
        const svg = document.createElementNS(ns, 'svg');
        svg.setAttribute('width', '12');
        svg.setAttribute('height', '12');
        svg.setAttribute('viewBox', '0 0 24 24');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('stroke', 'currentColor');
        svg.setAttribute('stroke-width', '2');
        svg.setAttribute('stroke-linecap', 'round');
        svg.setAttribute('stroke-linejoin', 'round');
        svg.setAttribute('class', 'shrink-0');
        const path = document.createElementNS(ns, 'path');
        path.setAttribute('d', 'M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z');
        const circle = document.createElementNS(ns, 'circle');
        circle.setAttribute('cx', '12');
        circle.setAttribute('cy', '10');
        circle.setAttribute('r', '3');
        svg.appendChild(path);
        svg.appendChild(circle);
        return svg;
    }

    function buildSpan(className: string, text: string): HTMLSpanElement {
        const span = document.createElement('span');
        span.className = className;
        span.textContent = text;
        return span;
    }

    function buildVenueChip(location: string): HTMLDivElement {
        const wrap = document.createElement('div');
        wrap.className = 'mt-2';

        const venue = resolveVenue(location);
        const chip = document.createElement('span');
        chip.appendChild(buildPinIcon());

        if (venue) {
            chip.className =
                'inline-flex max-w-full items-center gap-1 rounded-full bg-purple-50 text-purple-800 ring-1 ring-purple-100 px-2 py-0.5 text-xs';
            chip.title = `${venue.name} · ${venue.neighborhood}`;
            chip.appendChild(buildSpan('truncate font-medium', venue.name));
            chip.appendChild(buildSpan('text-purple-500', '·'));
            chip.appendChild(buildSpan('truncate text-purple-600', venue.neighborhood));
        } else {
            chip.className = 'inline-flex max-w-full items-center gap-1 text-gray-500 text-xs';
            chip.appendChild(buildSpan('truncate', location));
        }

        wrap.appendChild(chip);
        return wrap;
    }

    function loadSavedEvents() {
        const container = document.getElementById('savedEventsContainer');
        const empty = document.getElementById('noSavedEvents');
        if (!container || !empty) return;

        let saved: SavedEvent[] = [];
        try {
            saved = JSON.parse(localStorage.getItem('savedEvents') || '[]');
        } catch {
            saved = [];
        }

        container.replaceChildren();

        if (saved.length === 0) {
            empty.classList.remove('hidden');
            return;
        }

        empty.classList.add('hidden');
        saved.forEach((event) => {
            container.appendChild(buildEventCard(event));
        });
    }

    document.addEventListener('DOMContentLoaded', loadSavedEvents);
    window.addEventListener('storage', (e) => {
        if (e.key === 'savedEvents') loadSavedEvents();
    });
</script>

<style>
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
