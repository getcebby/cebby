---
import Layout from '../layouts/Layout.astro';
import AppHeader from '../components/AppHeader.astro';
import EventCard from '../components/EventCard.astro';
import SEO from '../components/SEO.astro';
import { supabase } from '../lib/supabase';
import type { AccountsFromDB, EventFromDB } from '../types/database';

const { data: partners } = (await supabase
    .from('accounts')
    .select('*')
    .order('name', { ascending: true })
    .limit(12)) as { data: AccountsFromDB[] | null; error: any };

// Live event data for the hero — proves the product is active.
// Prefer upcoming; if none, fall back to most-recent so the page never feels dead.
const now = new Date();
const horizonEnd = new Date();
horizonEnd.setDate(now.getDate() + 30);
const recentStart = new Date();
recentStart.setDate(now.getDate() - 30);

const { data: upcomingEvents } = (await supabase
    .from('events')
    .select('*,accounts!left(*)')
    .or('is_hidden.is.null,is_hidden.eq.false')
    .gte('start_time', now.toISOString())
    .lte('start_time', horizonEnd.toISOString())
    .order('start_time', { ascending: true })
    .limit(20)) as { data: EventFromDB[] | null; error: any };

const { data: recentEvents } = (await supabase
    .from('events')
    .select('*,accounts!left(*)')
    .or('is_hidden.is.null,is_hidden.eq.false')
    .gte('start_time', recentStart.toISOString())
    .lt('start_time', now.toISOString())
    .order('start_time', { ascending: false })
    .limit(5)) as { data: EventFromDB[] | null; error: any };

const upcomingCount = upcomingEvents?.length ?? 0;
const recentCount = recentEvents?.length ?? 0;
const hasUpcoming = upcomingCount > 0;
const heroEvent = hasUpcoming ? upcomingEvents![0] : (recentEvents?.[0] ?? null);
const heroEventLabel = hasUpcoming ? 'Up next' : 'Most recent';

const metaDescription =
    'All Cebu tech events. Weeks ahead. All sources. No algorithm. Cebby aggregates meetups, workshops, conferences, and hackathons from Luma, Eventbrite, Meetup, and Facebook into one calm feed.';

const faqs = [
    {
        q: 'How does Cebby find events?',
        a: "We aggregate from Luma, Eventbrite, Meetup, and Facebook every few hours. A small set of trusted Cebu tech organizers automatically pass through; everything else passes a quick review queue. No algorithm, no ranking — just a clean chronological feed.",
    },
    {
        q: 'Is Cebby free?',
        a: 'Yes, completely free. Cebby is a public utility for Cebu tech — no premium tier, no paywall, no native ads in the feed.',
    },
    {
        q: 'Do I need an account?',
        a: 'No. Browse events, save bookmarks, and subscribe to the calendar feed without signing up. Saved events live in your browser.',
    },
    {
        q: 'What about RSVPs?',
        a: "Cebby doesn't take RSVPs — we deep-link to where the event lives (Luma, Eventbrite, etc.) so organizers can manage attendees in their own tools.",
    },
    {
        q: 'How can I help?',
        a: 'Cebby is open source. Contributions of code, copy, or coffee are welcome — see the GitHub repo for ways to get involved.',
    },
];
---

<Layout title="cebby — Cebu tech events, all in one place" showFooter={true}>
    <Fragment slot="head">
        <SEO
            title="cebby — Cebu tech events, all in one place"
            description={metaDescription}
            image="/og.png"
            type="website"
        />
    </Fragment>

    <AppHeader showSearch={false} />

    <main class="mx-auto max-w-3xl px-5 pb-20 pt-2">
        {/* Hero */}
        <section class="mb-10 mt-4 text-center">
            <h1 class="mx-auto mb-4 max-w-2xl text-4xl font-extrabold leading-tight text-gray-900 sm:text-5xl">
                Cebu tech events, <br />
                <span class="text-purple-600">all in one place.</span>
            </h1>
            <p class="mx-auto mb-7 max-w-xl text-lg text-gray-500">
                Weeks ahead. All sources. No algorithm.
            </p>

            {/* Primary CTA + quiet secondary */}
            <div class="mb-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
                <a href="/events" class="press-sm btn-primary-tactile">
                    Browse events <span aria-hidden="true">→</span>
                </a>
                <a
                    href="/calendar"
                    class="press-sm inline-flex items-center gap-1.5 text-sm font-semibold text-gray-600 hover:text-purple-700"
                >
                    or subscribe to calendar
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                        <path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                </a>
            </div>

            {/* Live activity stat — proves the product is active */}
            <div class="inline-flex items-center gap-2 rounded-full bg-white/70 px-4 py-1.5 text-xs font-semibold text-gray-600 shadow-soft-1">
                <span class="relative flex h-2 w-2">
                    <span
                        class:list={[
                            'absolute inline-flex h-full w-full animate-ping rounded-full opacity-60',
                            hasUpcoming ? 'bg-emerald-400' : 'bg-amber-400',
                        ]}
                    />
                    <span
                        class:list={[
                            'relative inline-flex h-2 w-2 rounded-full',
                            hasUpcoming ? 'bg-emerald-500' : 'bg-amber-500',
                        ]}
                    />
                </span>
                {
                    hasUpcoming ? (
                        <span>
                            <span class="font-extrabold text-gray-900">{upcomingCount}</span>{' '}
                            {upcomingCount === 1 ? 'event' : 'events'} in the next 30 days
                        </span>
                    ) : recentCount > 0 ? (
                        <span>
                            Quiet week — last <span class="font-extrabold text-gray-900">{recentCount}</span> events in
                            the past 30 days
                        </span>
                    ) : (
                        <span>Quiet week — subscribe to catch the next event</span>
                    )
                }
            </div>
        </section>

        {/* Hero peek — most relevant single event, real product proof */}
        {
            heroEvent && (
                <section class="mb-14">
                    <div class="mb-3 flex items-baseline justify-between">
                        <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500">
                            {heroEventLabel}
                        </span>
                        <a href="/events" class="text-xs font-semibold text-purple-700 hover:text-purple-900">
                            See all →
                        </a>
                    </div>
                    <EventCard event={heroEvent} variant={hasUpcoming ? 'upcoming' : 'recent'} />
                </section>
            )
        }

        {/* Value props */}
        <section class="mb-12 grid gap-4 sm:grid-cols-3">
            <div class="card-tactile p-5">
                <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">Aggregated</div>
                <div class="mb-1 text-base font-extrabold text-gray-900">All sources, one feed</div>
                <p class="text-sm text-gray-500">Luma, Eventbrite, Meetup, Facebook — checked every few hours.</p>
            </div>
            <div class="card-tactile p-5">
                <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">Curated</div>
                <div class="mb-1 text-base font-extrabold text-gray-900">No platform fatigue</div>
                <p class="text-sm text-gray-500">Trusted Cebu tech organizers auto-flow. Spam stays out.</p>
            </div>
            <div class="card-tactile p-5">
                <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">Passive</div>
                <div class="mb-1 text-base font-extrabold text-gray-900">Subscribe and forget</div>
                <p class="text-sm text-gray-500">All events flow into your calendar — no app to remember to open.</p>
            </div>
        </section>

        {/* Partners */}
        {
            partners && partners.length > 0 && (
                <section class="mb-12">
                    <div class="mb-4 flex items-baseline justify-between">
                        <h2 class="text-xl font-bold text-gray-900">Trusted organizers</h2>
                        <a href="/partners" class="text-sm font-semibold text-purple-700 hover:text-purple-900">
                            See all →
                        </a>
                    </div>
                    <div class="card-tactile p-5">
                        <div class="grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6">
                            {partners.slice(0, 12).map((p) => (
                                <div class="flex flex-col items-center gap-2">
                                    {p.primary_photo ? (
                                        <img
                                            src={p.primary_photo}
                                            alt={p.name}
                                            loading="lazy"
                                            class="h-14 w-14 rounded-2xl object-cover shadow-soft-1"
                                        />
                                    ) : (
                                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-purple-50 text-lg font-extrabold text-purple-600 shadow-soft-1">
                                            {p.name.charAt(0)}
                                        </div>
                                    )}
                                    <div class="line-clamp-2 text-center text-[11px] font-semibold leading-tight text-gray-700">
                                        {p.name}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </section>
            )
        }

        {/* FAQ */}
        <section class="mb-12">
            <h2 class="mb-4 text-xl font-bold text-gray-900">Frequently asked</h2>
            <div class="space-y-3">
                {
                    faqs.map((faq) => (
                        <details class="card-tactile group p-5">
                            <summary class="cursor-pointer list-none text-base font-extrabold text-gray-900">
                                <span class="flex items-center justify-between gap-4">
                                    {faq.q}
                                    <svg
                                        width="18"
                                        height="18"
                                        viewBox="0 0 18 18"
                                        fill="none"
                                        class="flex-shrink-0 text-gray-400 transition-transform group-open:rotate-180"
                                    >
                                        <path d="M4 7l5 5 5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
                                    </svg>
                                </span>
                            </summary>
                            <p class="mt-3 text-sm text-gray-600">{faq.a}</p>
                        </details>
                    ))
                }
            </div>
        </section>

        {/* Bottom CTA */}
        <section class="text-center">
            <div class="card-tactile p-8">
                <h2 class="mb-2 text-xl font-extrabold text-gray-900">Ready to stop platform-hopping?</h2>
                <p class="mb-5 text-sm text-gray-500">
                    Open Cebby once, scan the week, leave. That's the whole product.
                </p>
                <a href="/events" class="press-sm btn-primary-tactile inline-flex">
                    Browse events <span aria-hidden="true">→</span>
                </a>
            </div>
        </section>
    </main>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
