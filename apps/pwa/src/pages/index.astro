---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import SEO from '../components/SEO.astro';
import { supabase } from '../lib/supabase';
import type { AccountsFromDB, EventFromDB } from '../types/database';

// Edge-cache the rendered HTML for 60s, serve stale up to 5min while revalidating.
// Homepage is identical across users; saves/RSVPs are client-side only.
Astro.response.headers.set(
    'Cache-Control',
    'public, max-age=0, s-maxage=60, stale-while-revalidate=300',
);

const { data: partners } = (await supabase
    .from('accounts')
    .select('*')
    .order('name', { ascending: true })
    .limit(12)) as { data: AccountsFromDB[] | null; error: any };

// Live event data for the hero — proves the product is active.
// Prefer upcoming; if none, fall back to most-recent so the page never feels dead.
const now = new Date();
const horizonEnd = new Date();
horizonEnd.setDate(now.getDate() + 30);
const recentStart = new Date();
recentStart.setDate(now.getDate() - 30);

// Pulls organizers + source_links so cards can show "Presented by …" and the
// detail page (when navigated via VT) hydrates with the multi-source data.
// FK-name disambiguation required for both joins: events has two paths to
// accounts (direct FK + via event_organizers) and two paths to
// event_source_links (one-to-many via event_id + many-to-one via
// primary_source_link_id back-reference).
const EVENT_LIST_SELECT =
    '*,organizers:event_organizers(role,position,accounts(*)),source_links:event_source_links!event_source_links_event_id_fkey(id,source,source_id,url,scraped_at)';

const { data: upcomingEvents } = (await supabase
    .from('events')
    .select(EVENT_LIST_SELECT)
    .neq('status', 'hidden')
    .gte('start_time', now.toISOString())
    .lte('start_time', horizonEnd.toISOString())
    .order('start_time', { ascending: true })
    .limit(20)) as { data: EventFromDB[] | null; error: any };

const { data: recentEvents } = (await supabase
    .from('events')
    .select(EVENT_LIST_SELECT)
    .neq('status', 'hidden')
    .gte('start_time', recentStart.toISOString())
    .lt('start_time', now.toISOString())
    .order('start_time', { ascending: false })
    .limit(5)) as { data: EventFromDB[] | null; error: any };

const upcomingCount = upcomingEvents?.length ?? 0;
const recentCount = recentEvents?.length ?? 0;
const hasUpcoming = upcomingCount > 0;
const heroEvent = hasUpcoming ? upcomingEvents![0] : (recentEvents?.[0] ?? null);
const heroEventLabel = hasUpcoming ? 'Up next' : 'Most recent';

const metaDescription =
    'All Cebu tech events. Weeks ahead. All sources. No algorithm. Cebby aggregates meetups, workshops, conferences, and hackathons from Luma, Eventbrite, Meetup, and Facebook into one calm feed.';

const faqs = [
    {
        q: 'How does Cebby find events?',
        a: 'We aggregate from Luma, Eventbrite, Meetup, and Facebook every few hours. A small set of trusted Cebu tech organizers automatically pass through; everything else passes a quick review queue. No algorithm, no ranking — just a clean chronological feed.',
    },
    {
        q: 'Is Cebby free?',
        a: 'Yes, completely free. Cebby is a public utility for Cebu tech — no premium tier, no paywall, no native ads in the feed.',
    },
    {
        q: 'Do I need an account?',
        a: 'No. Browse events, save bookmarks, and subscribe to the calendar feed without signing up. Saved events live in your browser.',
    },
    {
        q: 'What about RSVPs?',
        a: "Cebby doesn't take RSVPs — we deep-link to where the event lives (Luma, Eventbrite, etc.) so organizers can manage attendees in their own tools.",
    },
    {
        q: 'How can I help?',
        a: 'Cebby is open source — contributions of code, copy, or coffee are welcome via the GitHub repo. If you run a Cebu tech community and want your events on the directory, email hello@getcebby.com.',
    },
];
---

<Layout title="cebby — Cebu tech events, all in one place" showFooter={true}>
    <Fragment slot="head">
        <SEO
            title="cebby — Cebu tech events, all in one place"
            description={metaDescription}
            image="/og.png"
            type="website"
        />
    </Fragment>

    <main class="mx-auto max-w-3xl space-y-10 px-5 pb-20 pt-2">
        {/* Hero — wordmark is the logo */}
        <section class="mt-12 text-center sm:mt-20">
            <a
                href="/events"
                class="entrance-pop press-sm wordmark-link inline-block leading-none"
                aria-label="cebby — browse events"
            >
                <span class="wordmark text-7xl text-purple-600 lowercase sm:text-8xl" aria-hidden="true">
                    <span class="wordmark-letter">c</span><span class="wordmark-letter">e</span><span class="wordmark-letter">b</span><span class="wordmark-letter">b</span><span class="wordmark-letter">y</span>
                </span>
            </a>
            <h1 class="mt-4 text-lg font-medium text-gray-500 sm:text-xl">Cebu tech events, all in one place</h1>
            <p class="mx-auto mb-7 mt-2 max-w-xl text-sm text-gray-500">Weeks ahead. All sources. No algorithm.</p>

            {/* Primary CTA + quiet secondary */}
            <div class="mb-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
                <a href="/events" class="entrance-rise press-sm btn-primary-tactile" style="animation-delay: 200ms">
                    Browse events <span aria-hidden="true">→</span>
                </a>
                <a
                    href="/calendar"
                    class="entrance-rise press-sm group inline-flex items-center gap-1.5 text-sm font-semibold text-gray-600 transition-colors duration-200 hover:text-purple-700"
                    style="animation-delay: 280ms"
                >
                    or set it on your calendar
                    <svg
                        width="14"
                        height="14"
                        viewBox="0 0 14 14"
                        fill="none"
                        class="transition-transform duration-200 group-hover:translate-x-0.5 motion-reduce:group-hover:translate-x-0"
                    >
                        <path
                            d="M3 7h8M7 3l4 4-4 4"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </a>
            </div>

            {/* Live activity stat — proves the product is active */}
            <div
                class="entrance-rise inline-flex items-center gap-2 rounded-full bg-white/70 px-4 py-1.5 text-xs font-semibold text-gray-600 shadow-soft-1"
                style="animation-delay: 360ms"
            >
                <span class="relative flex h-2 w-2">
                    <span
                        class:list={[
                            'absolute inline-flex h-full w-full animate-ping rounded-full opacity-60',
                            hasUpcoming ? 'bg-emerald-400' : 'bg-amber-400',
                        ]}></span>
                    <span
                        class:list={[
                            'relative inline-flex h-2 w-2 rounded-full',
                            hasUpcoming ? 'bg-emerald-500' : 'bg-amber-500',
                        ]}></span>
                </span>
                {
                    hasUpcoming ? (
                        <span>
                            <span class="font-extrabold text-gray-900">{upcomingCount}</span>{' '}
                            {upcomingCount === 1 ? 'event' : 'events'} in the next 30 days
                        </span>
                    ) : recentCount > 0 ? (
                        <span>
                            Quiet week — last <span class="font-extrabold text-gray-900">{recentCount}</span> events in
                            the past 30 days
                        </span>
                    ) : (
                        <span>Quiet week — subscribe to catch the next event</span>
                    )
                }
            </div>
            <p class="mt-3 text-xs text-gray-500">Refreshed every few hours.</p>
        </section>

        {/* Hero peek — most relevant single event, real product proof */}
        {
            heroEvent && (
                <section class="home-section-in" style="animation-delay: 440ms">
                    <div class="mb-3 flex items-baseline justify-between">
                        <span class="text-[10px] font-bold uppercase tracking-widest text-gray-500">
                            {heroEventLabel}
                        </span>
                        <a
                            href="/events"
                            class="arrow-nudge text-xs font-semibold text-purple-700 hover:text-purple-900"
                        >
                            See all <span aria-hidden="true">→</span>
                        </a>
                    </div>
                    <EventCard event={heroEvent} variant={hasUpcoming ? 'upcoming' : 'recent'} />
                </section>
            )
        }

        {
            /* Value props — single card on mobile, three columns on desktop. The
            grouped card on mobile reads as one unit (less stop-and-start scroll). */
        }
        <section
            class="home-section-in lift-hover card-tactile divide-y divide-gray-100 p-1.5 sm:grid sm:grid-cols-3 sm:divide-x sm:divide-y-0 sm:p-2"
            style="animation-delay: 520ms"
        >
            <div class="p-4">
                <div class="mb-1 text-[10px] font-bold uppercase tracking-widest text-gray-500">Aggregated</div>
                <div class="mb-1 text-base font-extrabold text-gray-900">All sources, one feed</div>
                <p class="text-sm text-gray-500">Luma, Eventbrite, Meetup, Facebook — all in one place.</p>
            </div>
            <div class="p-4">
                <div class="mb-1 text-[10px] font-bold uppercase tracking-widest text-gray-500">Curated</div>
                <div class="mb-1 text-base font-extrabold text-gray-900">No platform fatigue</div>
                <p class="text-sm text-gray-500">Cebby partners auto-flow. Everyone else passes review.</p>
            </div>
            <div class="p-4">
                <div class="mb-1 text-[10px] font-bold uppercase tracking-widest text-gray-500">Passive</div>
                <div class="mb-1 text-base font-extrabold text-gray-900">Subscribe once. Forget.</div>
                <p class="text-sm text-gray-500">All events flow into your calendar — no app to remember to open.</p>
            </div>
        </section>

        {/* Partners */}
        {
            partners && partners.length > 0 && (
                <section class="home-section-in" style="animation-delay: 600ms">
                    <header class="mb-4">
                        <div class="flex items-baseline justify-between">
                            <h2 class="text-xl font-bold text-gray-900">Community partners</h2>
                            <a
                                href="/partners"
                                class="arrow-nudge text-sm font-semibold text-purple-700 hover:text-purple-900"
                            >
                                See all <span aria-hidden="true">→</span>
                            </a>
                        </div>
                        <p class="mt-1 text-sm text-gray-500">
                            Trusted Cebu tech organizers — their events auto-flow into the feed.
                        </p>
                    </header>
                    <div class="card-tactile p-5">
                        <div class="grid grid-cols-3 gap-4 sm:grid-cols-4 md:grid-cols-6">
                            {partners.slice(0, 12).map((p) => (
                                <div class="group flex flex-col items-center gap-2">
                                    {p.primary_photo ? (
                                        <img
                                            src={p.primary_photo}
                                            alt={p.name}
                                            loading="lazy"
                                            class="h-14 w-14 rounded-2xl object-cover shadow-soft-1 transition-transform duration-200 group-hover:scale-110 motion-reduce:group-hover:scale-100"
                                        />
                                    ) : (
                                        <div class="flex h-14 w-14 items-center justify-center rounded-2xl bg-purple-50 text-lg font-extrabold text-purple-600 shadow-soft-1 transition-transform duration-200 group-hover:scale-110 motion-reduce:group-hover:scale-100">
                                            {p.name.charAt(0)}
                                        </div>
                                    )}
                                    <div class="line-clamp-2 text-center text-[11px] font-semibold leading-tight text-gray-700 transition-colors duration-200 group-hover:text-purple-700">
                                        {p.name}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </section>
            )
        }

        {/* FAQ */}
        <section class="home-section-in" style="animation-delay: 680ms">
            <h2 class="mb-4 text-xl font-bold text-gray-900">Frequently asked</h2>
            <div class="space-y-3">
                {
                    faqs.map((faq) => (
                        <details class="card-tactile group p-5">
                            <summary class="cursor-pointer list-none text-base font-extrabold text-gray-900 transition-colors duration-200 hover:text-purple-700">
                                <span class="flex items-center justify-between gap-4">
                                    {faq.q}
                                    <svg
                                        width="18"
                                        height="18"
                                        viewBox="0 0 18 18"
                                        fill="none"
                                        class="flex-shrink-0 text-gray-400 transition-transform duration-200 group-hover:text-purple-500 group-open:rotate-180"
                                    >
                                        <path
                                            d="M4 7l5 5 5-5"
                                            stroke="currentColor"
                                            stroke-width="1.75"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        />
                                    </svg>
                                </span>
                            </summary>
                            <p class="mt-3 text-sm text-gray-600">{faq.a}</p>
                        </details>
                    ))
                }
            </div>
        </section>

        {/* Bottom CTA */}
        <section class="home-section-in text-center" style="animation-delay: 760ms">
            <div class="card-tactile p-8">
                <h2 class="mb-2 text-xl font-extrabold text-gray-900">Ready to stop platform-hopping?</h2>
                <p class="mb-5 text-sm text-gray-500">Open Cebby once, scan the week, leave. That's the whole point.</p>
                <a href="/events" class="press-sm btn-primary-tactile inline-flex">
                    Browse events <span aria-hidden="true">→</span>
                </a>
            </div>
        </section>
    </main>
</Layout>

<style>
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    @keyframes home-section-in {
        0%   { transform: translateY(10px); opacity: 0; }
        100% { transform: translateY(0); opacity: 1; }
    }
    .home-section-in {
        animation: home-section-in 360ms cubic-bezier(0.2, 0, 0, 1) backwards;
    }
    @media (prefers-reduced-motion: reduce) {
        .home-section-in {
            animation: none;
        }
    }
</style>
