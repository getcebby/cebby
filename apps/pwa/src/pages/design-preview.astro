---
export const prerender = true;
---

<!doctype html>
<html lang="en" class="h-full">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <title>cebby — design preview</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Caveat:wght@700&display=swap"
            rel="stylesheet"
        />
        <style>
            html,
            body {
                font-family:
                    'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                background:
                    radial-gradient(ellipse 80% 40% at 50% 0%, rgba(168, 85, 247, 0.06) 0%, transparent 60%),
                    radial-gradient(ellipse 60% 30% at 100% 20%, rgba(251, 191, 36, 0.05) 0%, transparent 60%),
                    radial-gradient(ellipse 60% 30% at 0% 30%, rgba(34, 197, 94, 0.04) 0%, transparent 60%),
                    #fafaf9;
                background-attachment: fixed;
                color: #1f1f1f;
                -webkit-font-smoothing: antialiased;
                -moz-osx-font-smoothing: grayscale;
            }
            .wordmark {
                font-family: 'Caveat', cursive;
                font-weight: 700;
                letter-spacing: -0.01em;
            }
            /* Soft elevation tokens — pushed harder for game-UI dimensional feel */
            .shadow-soft-1 {
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.9),
                    0 1px 2px rgba(15, 15, 15, 0.05),
                    0 4px 12px rgba(15, 15, 15, 0.05),
                    0 8px 24px rgba(15, 15, 15, 0.04);
            }
            .shadow-soft-2 {
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.95),
                    0 1px 2px rgba(15, 15, 15, 0.06),
                    0 6px 16px rgba(15, 15, 15, 0.07),
                    0 16px 32px rgba(15, 15, 15, 0.06);
            }
            .shadow-soft-3 {
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.95),
                    0 1px 2px rgba(15, 15, 15, 0.08),
                    0 8px 20px rgba(15, 15, 15, 0.1),
                    0 24px 48px rgba(15, 15, 15, 0.08);
            }
            .shadow-purple-cta {
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.35),
                    inset 0 -1px 0 rgba(0, 0, 0, 0.12),
                    0 1px 2px rgba(80, 20, 160, 0.2),
                    0 6px 14px rgba(147, 51, 234, 0.4),
                    0 12px 28px rgba(147, 51, 234, 0.22);
            }
            /* Tactile pill — physical, pressable, gradient-filled */
            .pill-tactile {
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                padding: 0.4rem 0.85rem;
                border-radius: 14px;
                font-weight: 700;
                font-size: 12px;
                line-height: 1;
                letter-spacing: 0.01em;
                position: relative;
            }
            .pill-emerald {
                background: linear-gradient(180deg, #ecfdf5 0%, #a7f3d0 100%);
                color: #047857;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.7),
                    inset 0 -1px 0 rgba(4, 120, 87, 0.15),
                    0 1px 2px rgba(4, 120, 87, 0.12),
                    0 2px 6px rgba(4, 120, 87, 0.1);
            }
            .pill-amber {
                background: linear-gradient(180deg, #fffbeb 0%, #fcd34d 100%);
                color: #92400e;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.8),
                    inset 0 -1px 0 rgba(146, 64, 14, 0.15),
                    0 1px 2px rgba(146, 64, 14, 0.12),
                    0 2px 6px rgba(146, 64, 14, 0.1);
            }
            .pill-rose {
                background: linear-gradient(180deg, #fff1f2 0%, #fda4af 100%);
                color: #9f1239;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.7),
                    inset 0 -1px 0 rgba(159, 18, 57, 0.15),
                    0 1px 2px rgba(159, 18, 57, 0.12),
                    0 2px 6px rgba(159, 18, 57, 0.1);
            }
            .pill-blue {
                background: linear-gradient(180deg, #eff6ff 0%, #93c5fd 100%);
                color: #1e40af;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.7),
                    inset 0 -1px 0 rgba(30, 64, 175, 0.15),
                    0 1px 2px rgba(30, 64, 175, 0.12),
                    0 2px 6px rgba(30, 64, 175, 0.1);
            }
            .pill-stone {
                background: linear-gradient(180deg, #fafaf9 0%, #d6d3d1 100%);
                color: #44403c;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.7),
                    inset 0 -1px 0 rgba(68, 64, 60, 0.12),
                    0 1px 2px rgba(68, 64, 60, 0.1),
                    0 2px 6px rgba(68, 64, 60, 0.08);
            }
            /* Filter chips — same physics, larger */
            .chip-tactile {
                display: inline-flex;
                align-items: center;
                gap: 0.4rem;
                padding: 0.55rem 1rem;
                border-radius: 999px;
                font-weight: 600;
                font-size: 14px;
                transition: all 160ms cubic-bezier(0.2, 0, 0, 1);
            }
            .chip-inactive {
                background: linear-gradient(180deg, #ffffff 0%, #f5f5f4 100%);
                color: #44403c;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 1),
                    inset 0 -1px 0 rgba(0, 0, 0, 0.04),
                    0 1px 2px rgba(15, 15, 15, 0.05),
                    0 4px 8px rgba(15, 15, 15, 0.04);
            }
            .chip-active {
                background: linear-gradient(180deg, #c084fc 0%, #9333ea 100%);
                color: white;
                font-weight: 700;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.4),
                    inset 0 -1px 0 rgba(0, 0, 0, 0.15),
                    0 1px 2px rgba(80, 20, 160, 0.25),
                    0 4px 12px rgba(147, 51, 234, 0.35);
            }
            /* Card — subtle vertical gradient + heavier elevation */
            .card-tactile {
                background: linear-gradient(180deg, #ffffff 0%, #fafaf9 100%);
                border-radius: 24px;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 1),
                    inset 0 0 0 1px rgba(15, 15, 15, 0.03),
                    0 1px 2px rgba(15, 15, 15, 0.06),
                    0 8px 20px rgba(15, 15, 15, 0.06),
                    0 20px 40px rgba(15, 15, 15, 0.05);
            }
            /* CTA button — game-UI primary action */
            .btn-primary-tactile {
                background: linear-gradient(180deg, #a855f7 0%, #7e22ce 100%);
                color: white;
                font-weight: 700;
                padding: 0.55rem 1.1rem;
                border-radius: 999px;
                font-size: 13px;
                letter-spacing: 0.01em;
                display: inline-flex;
                align-items: center;
                gap: 0.35rem;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.4),
                    inset 0 -2px 0 rgba(0, 0, 0, 0.15),
                    0 1px 2px rgba(80, 20, 160, 0.25),
                    0 4px 10px rgba(147, 51, 234, 0.35),
                    0 10px 20px rgba(147, 51, 234, 0.2);
            }
            /* Date chip on cards — tactile mini surface */
            .date-chip {
                background: linear-gradient(180deg, #ffffff 0%, #f5f5f4 100%);
                border-radius: 14px;
                padding: 0.5rem 0.75rem;
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 1),
                    inset 0 0 0 1px rgba(15, 15, 15, 0.04),
                    0 2px 4px rgba(15, 15, 15, 0.06),
                    0 4px 12px rgba(15, 15, 15, 0.05);
            }
            .date-chip-purple {
                background: linear-gradient(180deg, #faf5ff 0%, #e9d5ff 100%);
                box-shadow:
                    inset 0 1px 0 rgba(255, 255, 255, 0.9),
                    inset 0 0 0 1px rgba(147, 51, 234, 0.12),
                    0 2px 4px rgba(147, 51, 234, 0.15),
                    0 4px 12px rgba(147, 51, 234, 0.12);
            }
            .press {
                transition:
                    transform 160ms cubic-bezier(0.2, 0, 0, 1),
                    box-shadow 160ms cubic-bezier(0.2, 0, 0, 1);
            }
            .press:active {
                transform: scale(0.985) translateY(1px);
            }
            .press-sm:active {
                transform: scale(0.94);
            }
        </style>
    </head>
    <body class="min-h-screen">
        <main class="mx-auto max-w-2xl px-5 pt-10 pb-32">
            <!-- Wordmark + minimal top bar -->
            <header class="mb-8 flex items-center justify-between">
                <h1 class="wordmark text-5xl text-purple-600 lowercase leading-none">cebby</h1>
                <button
                    class="press-sm flex h-10 w-10 items-center justify-center rounded-full bg-white text-gray-700 shadow-soft-1"
                    aria-label="Search"
                >
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                        <path
                            d="M8 14a6 6 0 100-12 6 6 0 000 12zM16 16l-3.5-3.5"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"></path>
                    </svg>
                </button>
            </header>

            <!-- Hero "This week" stats -->
            <section class="mb-8">
                <div class="mb-4 flex items-baseline justify-between">
                    <h2 class="text-xl font-bold text-gray-900">This week in Cebu tech</h2>
                    <span class="text-xs font-medium text-gray-500">Apr 26 – May 2</span>
                </div>
                <div class="grid grid-cols-2 gap-3">
                    <div class="card-tactile p-5">
                        <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">
                            Events
                        </div>
                        <div class="mb-2 text-4xl font-extrabold leading-none text-gray-900">7</div>
                        <div class="flex items-center gap-1 text-xs font-bold text-emerald-700">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                                <path
                                    d="M3 9L9 3M9 3H4M9 3V8"
                                    stroke="currentColor"
                                    stroke-width="1.75"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"></path>
                            </svg>
                            +3 vs last week
                        </div>
                    </div>
                    <div class="card-tactile p-5">
                        <div class="mb-2 text-[10px] font-bold uppercase tracking-widest text-gray-500">
                            New today
                        </div>
                        <div class="mb-2 text-4xl font-extrabold leading-none text-gray-900">2</div>
                        <div class="text-xs font-medium text-gray-500">since yesterday</div>
                    </div>
                </div>
            </section>

            <!-- Filter chips -->
            <section class="mb-6">
                <div class="flex flex-wrap gap-2.5">
                    <button class="press-sm chip-tactile chip-active">All</button>
                    <button class="press-sm chip-tactile chip-inactive">This week</button>
                    <button class="press-sm chip-tactile chip-inactive">Free</button>
                    <button class="press-sm chip-tactile chip-inactive">Beginner</button>
                    <button class="press-sm chip-tactile chip-inactive">Hiring</button>
                </div>
            </section>

            <!-- Event cards -->
            <section class="space-y-5">
                <!-- Card 1: with cover photo -->
                <article class="press card-tactile cursor-pointer overflow-hidden">
                    <div
                        class="relative aspect-[16/9] bg-gradient-to-br from-purple-300 via-purple-200 to-stone-100"
                    >
                        <div class="date-chip absolute left-4 top-4 text-center">
                            <div class="text-xl font-extrabold leading-none text-gray-900">28</div>
                            <div
                                class="mt-1 text-[10px] font-bold uppercase tracking-wider text-gray-500"
                            >
                                Apr
                            </div>
                        </div>
                    </div>
                    <div class="p-5">
                        <div class="mb-3 flex gap-2">
                            <span class="pill-tactile pill-emerald">Free</span>
                            <span class="pill-tactile pill-amber">Beginner</span>
                        </div>
                        <h3 class="mb-1.5 text-lg font-extrabold leading-snug text-gray-900">
                            CebuJS April Meetup: Server Components Deep Dive
                        </h3>
                        <p class="mb-4 text-sm text-gray-500">
                            Sat, 6:30 PM · Cebu IT Park · CebuJS
                        </p>
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-medium text-gray-400">via Luma</span>
                            <button class="press-sm btn-primary-tactile">
                                RSVP on Luma <span aria-hidden="true">→</span>
                            </button>
                        </div>
                    </div>
                </article>

                <!-- Card 2: no cover photo, paid + hiring -->
                <article class="press card-tactile cursor-pointer overflow-hidden">
                    <div class="p-5">
                        <div class="mb-3 flex items-start justify-between gap-3">
                            <div class="date-chip date-chip-purple inline-block text-center">
                                <div class="text-xl font-extrabold leading-none text-purple-900">02</div>
                                <div
                                    class="mt-1 text-[10px] font-bold uppercase tracking-wider text-purple-700"
                                >
                                    May
                                </div>
                            </div>
                            <div class="flex flex-wrap justify-end gap-2">
                                <span class="pill-tactile pill-rose">Paid</span>
                                <span class="pill-tactile pill-blue">Hiring</span>
                            </div>
                        </div>
                        <h3 class="mb-1.5 text-lg font-extrabold leading-snug text-gray-900">
                            Geeks On Tour Cebu: AI in Production
                        </h3>
                        <p class="mb-4 text-sm text-gray-500">
                            Fri, 7:00 PM · The Company Cebu · GeeksOnTour
                        </p>
                        <div class="flex items-center justify-between">
                            <span class="text-xs font-medium text-gray-400">via Eventbrite</span>
                            <button class="press-sm btn-primary-tactile">
                                RSVP on Eventbrite <span aria-hidden="true">→</span>
                            </button>
                        </div>
                    </div>
                </article>

                <!-- Card 3: minimal, no badges -->
                <article class="press card-tactile cursor-pointer overflow-hidden">
                    <div class="p-5">
                        <div class="mb-3 flex items-start justify-between">
                            <div class="date-chip inline-block text-center">
                                <div class="text-xl font-extrabold leading-none text-gray-900">10</div>
                                <div
                                    class="mt-1 text-[10px] font-bold uppercase tracking-wider text-gray-500"
                                >
                                    May
                                </div>
                            </div>
                            <span class="pill-tactile pill-stone">Online</span>
                        </div>
                        <h3 class="mb-1.5 text-lg font-extrabold leading-snug text-gray-900">
                            DevCon Cebu Monthly Mixer
                        </h3>
                        <p class="text-sm text-gray-500">Sat, 5:00 PM · TBA · DevCon Cebu</p>
                    </div>
                </article>

                <!-- "View all" - quiet CTA pattern -->
                <button
                    class="press w-full rounded-2xl px-5 py-4 text-sm font-bold text-gray-700 chip-inactive hover:text-purple-700"
                    style="border-radius: 24px;"
                >
                    View all 7 events this week
                </button>
            </section>

            <!-- Calendar subscribe nudge — passive re-engagement -->
            <section class="mt-10">
                <div class="card-tactile flex items-center gap-4 p-5">
                    <div
                        class="date-chip date-chip-purple flex h-12 w-12 flex-shrink-0 items-center justify-center"
                        style="padding: 0"
                    >
                        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" class="text-purple-700">
                            <path
                                d="M3 8h16M5 4h12a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2zM7 2v4M15 2v4"
                                stroke="currentColor"
                                stroke-width="1.75"
                                stroke-linecap="round"></path>
                        </svg>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="text-sm font-extrabold text-gray-900">
                            Never miss a Cebu tech event
                        </div>
                        <div class="text-xs text-gray-500 mt-0.5">
                            Subscribe once, all events appear in your calendar.
                        </div>
                    </div>
                    <button class="press-sm btn-primary-tactile flex-shrink-0">
                        Subscribe
                    </button>
                </div>
            </section>
        </main>

        <!-- Bottom tab bar — floating tactile dock -->
        <nav
            class="fixed bottom-4 left-1/2 -translate-x-1/2"
            style="padding-bottom: env(safe-area-inset-bottom)"
        >
            <div
                class="flex items-stretch gap-1 rounded-3xl p-2"
                style="
                    background: linear-gradient(180deg, #ffffff 0%, #fafaf9 100%);
                    box-shadow:
                        inset 0 1px 0 rgba(255, 255, 255, 1),
                        inset 0 0 0 1px rgba(15, 15, 15, 0.04),
                        0 1px 2px rgba(15, 15, 15, 0.06),
                        0 8px 20px rgba(15, 15, 15, 0.1),
                        0 24px 48px rgba(15, 15, 15, 0.08);
                "
            >
                <a
                    href="#"
                    class="press-sm flex w-20 flex-col items-center justify-center gap-1 rounded-2xl px-3 py-2.5 text-white"
                    style="
                        background: linear-gradient(180deg, #c084fc 0%, #9333ea 100%);
                        box-shadow:
                            inset 0 1px 0 rgba(255, 255, 255, 0.4),
                            inset 0 -1px 0 rgba(0, 0, 0, 0.15),
                            0 1px 2px rgba(80, 20, 160, 0.25),
                            0 4px 12px rgba(147, 51, 234, 0.4);
                    "
                >
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <path
                            d="M3 9.5L11 3l8 6.5V19a1 1 0 01-1 1h-4v-6h-6v6H4a1 1 0 01-1-1V9.5z"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linejoin="round"
                            fill="rgba(255,255,255,0.18)"></path>
                    </svg>
                    <span class="text-[11px] font-bold">Events</span>
                </a>
                <a
                    href="#"
                    class="press-sm flex w-20 flex-col items-center justify-center gap-1 rounded-2xl px-3 py-2.5 text-gray-500"
                >
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <path
                            d="M3 8h16M5 4h12a2 2 0 012 2v12a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2zM7 2v4M15 2v4"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linecap="round"></path>
                    </svg>
                    <span class="text-[11px] font-semibold">Calendar</span>
                </a>
                <a
                    href="#"
                    class="press-sm flex w-20 flex-col items-center justify-center gap-1 rounded-2xl px-3 py-2.5 text-gray-500"
                >
                    <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
                        <path
                            d="M5 3h12a1 1 0 011 1v16l-7-4-7 4V4a1 1 0 011-1z"
                            stroke="currentColor"
                            stroke-width="1.75"
                            stroke-linejoin="round"></path>
                    </svg>
                    <span class="text-[11px] font-semibold">Saved</span>
                </a>
            </div>
        </nav>
    </body>
</html>
